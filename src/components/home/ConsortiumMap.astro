---
// Interactive Consortium Map - Shows CLIF sites with institution logos
import { readFile } from 'fs/promises';
import { join } from 'path';

// Read and parse the CSV file at build time
const csvPath = join(process.cwd(), 'src', 'data', 'site_details.csv');
const csvContent = await readFile(csvPath, 'utf-8');
const lines = csvContent.trim().split('\n');

// Parse CSV helper
function parseCSVLine(line: string): string[] {
  const result: string[] = [];
  let current = '';
  let inQuotes = false;
  for (let i = 0; i < line.length; i++) {
    const char = line[i];
    if (char === '"') {
      inQuotes = !inQuotes;
    } else if (char === ',' && !inQuotes) {
      result.push(current);
      current = '';
    } else {
      current += char;
    }
  }
  result.push(current);
  return result;
}

interface SiteData {
  name: string;
  location: string;
  latitude: number;
  longitude: number;
  dataReady: boolean;
  hospitals: number;
  encounters: number;
  patients: number;
  logoFile: string | null;
}

// Logo mapping: site name substring → logo filename
const logoMap: Record<string, string> = {
  'Emory': 'emory.png',
  'Johns Hopkins': 'jhu.png',
  'Northwestern': 'nw.png',
  'Oregon Health': 'ohsu.png',
  'Rush': 'rush.png',
  'San Francisco': 'ucsf.png',
  'University of Chicago': 'ucmc.png',
  'University of Michigan': 'umich.png',
  'University of Minnesota': 'umn.png',
  'University of Pennsylvania': 'upenn.png',
  'University of Toronto': 'utor.png',
  'Cornell': 'cornell.png',
  'Harvard': 'harvard.png',
  'University of Colorado': 'cu.png',
  'Yale': 'yale.png',
};

function findLogo(siteName: string): string | null {
  for (const [key, file] of Object.entries(logoMap)) {
    if (siteName.includes(key)) return file;
  }
  return null;
}

const sites: SiteData[] = [];
for (let i = 1; i < lines.length; i++) {
  const values = parseCSVLine(lines[i]);
  if (values.length >= 8) {
    const latStr = values[2].trim().replace(/−/g, '-');
    const lonStr = values[3].trim().replace(/−/g, '-');
    const name = values[0].trim();
    sites.push({
      name,
      location: values[1].trim(),
      latitude: parseFloat(latStr),
      longitude: parseFloat(lonStr),
      dataReady: values[4].trim().toLowerCase() === 'yes',
      hospitals: values[5].trim() ? parseInt(values[5].trim().replace(/,/g, '')) : 0,
      encounters: values[6].trim() ? parseInt(values[6].trim().replace(/,/g, '')) : 0,
      patients: values[7].trim() ? parseInt(values[7].trim().replace(/,/g, '')) : 0,
      logoFile: findLogo(name),
    });
  }
}

const totalInstitutions = sites.length;
const activeSites = sites.filter(s => s.dataReady).length;
const upcomingSites = sites.filter(s => !s.dataReady).length;
const totalHospitals = sites.reduce((sum, s) => sum + s.hospitals, 0);
const totalPatients = sites.reduce((sum, s) => sum + s.patients, 0);

const sitesJSON = JSON.stringify(sites);
---

<section class="mb-16 px-4 relative z-0">
  <div class="max-w-[95vw] mx-auto">
    <!-- Map Container -->
    <div class="relative rounded-xl shadow-lg overflow-hidden border border-gray-200 dark:border-gray-700">
      <div id="consortium-map" class="h-[300px] sm:h-[500px] md:h-[600px] bg-gray-100 dark:bg-gray-800"></div>

      <!-- Legend -->
      <div class="absolute bottom-4 left-4 bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm px-4 py-3 rounded-lg shadow-md z-[1000] border border-gray-200/50 dark:border-gray-700/50">
        <div class="flex items-center gap-2.5">
          <svg viewBox="0 0 30 50" class="w-4 h-7 drop-shadow-sm" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <radialGradient id="legendPinDome" cx="38%" cy="32%" r="70%">
                <stop offset="0%" stop-color="#fecaca"/>
                <stop offset="35%" stop-color="#ef4444"/>
                <stop offset="100%" stop-color="#7f1d1d"/>
              </radialGradient>
              <linearGradient id="legendPinNeck" x1="0%" x2="100%">
                <stop offset="0%" stop-color="#7f1d1d"/>
                <stop offset="50%" stop-color="#dc2626"/>
                <stop offset="100%" stop-color="#7f1d1d"/>
              </linearGradient>
              <linearGradient id="legendPinDisc" x1="0%" x2="100%">
                <stop offset="0%" stop-color="#991b1b"/>
                <stop offset="50%" stop-color="#dc2626"/>
                <stop offset="100%" stop-color="#7f1d1d"/>
              </linearGradient>
              <linearGradient id="legendPinNeedle" x1="0%" x2="100%">
                <stop offset="0%" stop-color="#6b7280"/>
                <stop offset="50%" stop-color="#f3f4f6"/>
                <stop offset="100%" stop-color="#374151"/>
              </linearGradient>
            </defs>
            <path d="M13.5 22 L16.5 22 L15.5 47 L14.5 47 Z" fill="url(#legendPinNeedle)"/>
            <ellipse cx="15" cy="22" rx="10" ry="2.5" fill="#7f1d1d"/>
            <ellipse cx="15" cy="20.5" rx="10" ry="2.5" fill="url(#legendPinDisc)"/>
            <rect x="11" y="11" width="8" height="9.5" fill="url(#legendPinNeck)"/>
            <ellipse cx="15" cy="11" rx="11" ry="9" fill="url(#legendPinDome)"/>
            <ellipse cx="11" cy="8" rx="3" ry="2" fill="rgba(255,255,255,0.55)"/>
          </svg>
          <span class="text-xs font-medium text-gray-700 dark:text-gray-300">Coming Soon ({upcomingSites})</span>
        </div>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="flex justify-center gap-6 sm:gap-10 mt-5">
      <div class="text-center">
        <div class="text-2xl font-bold text-clif-burgundy">{totalInstitutions}</div>
        <div class="text-xs text-gray-500 dark:text-gray-400 font-medium uppercase tracking-wide">Institutions</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-clif-burgundy">{totalHospitals}</div>
        <div class="text-xs text-gray-500 dark:text-gray-400 font-medium uppercase tracking-wide">Hospitals</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-clif-burgundy">{activeSites}</div>
        <div class="text-xs text-gray-500 dark:text-gray-400 font-medium uppercase tracking-wide">Active Sites</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-clif-burgundy">{totalPatients.toLocaleString()}</div>
        <div class="text-xs text-gray-500 dark:text-gray-400 font-medium uppercase tracking-wide">Patients</div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Leaflet marker overrides */
  :global(.consortium-logo-marker) {
    background: none !important;
    border: none !important;
  }
  :global(.logo-marker) {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  :global(.logo-marker.has-pin) {
    flex-direction: column;
    gap: 0;
  }
  :global(.pin-icon) {
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 3px 4px rgba(0, 0, 0, 0.35));
    margin-bottom: -4px;
    z-index: 2;
  }
  :global(.pin-icon svg) {
    width: 100%;
    height: 100%;
    transform-origin: 50% 94%;
    animation: pin-wobble 2.4s ease-in-out infinite;
  }
  :global(.logo-marker.has-pin:hover .pin-icon svg) {
    animation-play-state: paused;
  }
  @keyframes pin-wobble {
    0%, 100% { transform: rotate(-7deg); }
    50%      { transform: rotate(7deg); }
  }
  :global(.logo-marker .logo-box) {
    background: none;
    border: none;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    transition: transform 0.2s ease;
  }
  :global(.logo-marker:hover .logo-box) {
    transform: scale(1.2);
  }
  :global(.logo-marker .logo-box img) {
    height: 80px;
    width: auto;
    min-width: 60px;
    max-width: 160px;
    object-fit: contain;
    display: block;
    opacity: 1 !important;
  }
  @media (max-width: 639px) {
    :global(.logo-marker .logo-box img) {
      height: 22px !important;
      min-width: 16px;
      max-width: 50px;
    }
    :global(.logo-marker .text-fallback) {
      width: 22px;
      height: 22px;
      font-size: 8px;
    }
  }
  :global(.logo-marker .text-fallback) {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #8B1538;
    border: 2.5px solid white;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 700;
    font-size: 14px;
    font-family: 'Inter', system-ui, sans-serif;
    position: relative;
    z-index: 1;
    transition: transform 0.2s ease;
  }
  :global(.logo-marker:hover .text-fallback) {
    transform: scale(1.15);
  }

  /* Dark mode marker adjustments */
  :global(.dark .logo-marker .logo-box img) {
    filter: brightness(1.3);
  }

  /* Tooltip styling */
  :global(.consortium-tooltip) {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    padding: 8px 12px;
    min-width: 160px;
  }
  :global(.consortium-tooltip .tt-name) {
    font-size: 14px;
    font-weight: 600;
    color: #1f2937;
    margin-bottom: 2px;
  }
  :global(.consortium-tooltip .tt-location) {
    font-size: 12px;
    color: #6b7280;
    margin-bottom: 6px;
  }
  :global(.consortium-tooltip .tt-stats) {
    font-size: 11px;
    color: #6b7280;
    border-top: 1px solid #e5e7eb;
    padding-top: 6px;
    margin-top: 4px;
  }
  :global(.consortium-tooltip .tt-badge) {
    display: inline-block;
    padding: 1px 8px;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 600;
  }
  :global(.consortium-tooltip .tt-badge.active) {
    background: #d1fae5;
    color: #065f46;
  }
  :global(.consortium-tooltip .tt-badge.upcoming) {
    background: #e5e7eb;
    color: #374151;
  }

  :global(.leaflet-tooltip) {
    border-radius: 10px !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15) !important;
    border: 1px solid rgba(0, 0, 0, 0.08) !important;
    padding: 0 !important;
  }

  :global(.leaflet-container) {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  /* Hide default leaflet attribution styling clutter */
  :global(.leaflet-control-attribution) {
    font-size: 10px !important;
    background: rgba(255,255,255,0.7) !important;
    padding: 2px 6px !important;
  }
  :global(.dark .leaflet-control-attribution) {
    background: rgba(17,24,39,0.7) !important;
    color: #9ca3af !important;
  }
  :global(.dark .leaflet-control-attribution a) {
    color: #9ca3af !important;
  }
</style>

<script define:vars={{ sitesJSON }}>
  const sites = JSON.parse(sitesJSON);

  const LIGHT_TILES = 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png';
  const DARK_TILES = 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png';
  const ATTRIBUTION = '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>';

  let map = null;
  let tileLayer = null;

  function isDarkMode() {
    return document.documentElement.classList.contains('dark');
  }

  function createTooltipContent(site) {
    let html = `<div class="consortium-tooltip">
      <div class="tt-name">${site.name}</div>
      <div class="tt-location">${site.location}</div>`;

    if (site.dataReady) {
      html += `<div class="tt-stats">
        ${site.hospitals} hospital${site.hospitals !== 1 ? 's' : ''} &middot; ${site.patients.toLocaleString()} patients
      </div>`;
      html += `<div style="margin-top:6px"><span class="tt-badge active">Active</span></div>`;
    } else {
      html += `<div style="margin-top:4px"><span class="tt-badge upcoming">Coming Soon</span></div>`;
    }

    html += `</div>`;
    return html;
  }

  function initMap() {
    if (typeof L === 'undefined') return;

    const mapEl = document.getElementById('consortium-map');
    if (!mapEl || map) return;

    const isMobile = window.innerWidth < 640;
    const sizeScale = isMobile ? 0.25 : 1;
    const offsetScale = isMobile ? 0.3 : 1;

    map = L.map('consortium-map', {
      center: isMobile ? [38, -92] : [45, -98],
      zoom: isMobile ? 2.5 : 4.5,
      minZoom: isMobile ? 2 : 4,
      maxZoom: 6,
      zoomControl: false,
      scrollWheelZoom: false,
      dragging: false,
      doubleClickZoom: false,
      touchZoom: false,
      attributionControl: true,
      maxBounds: L.latLngBounds(L.latLng(30, -250), L.latLng(48, -20)),
      maxBoundsViscosity: 1.0,
    });

    tileLayer = L.tileLayer(isDarkMode() ? DARK_TILES : LIGHT_TILES, {
      attribution: ATTRIBUTION,
      maxZoom: 18,
      subdomains: 'abcd',
    }).addTo(map);

    // Offset overlapping sites (Chicago cluster, Boston cluster)
    const offsets = {
      'Rush University': [0.2, -1.5],
      'Northwestern University': [-0.8, -2.5],
      'University of Chicago': [-1.7, -1.5],
      'University of Toronto': [1.7, -1.3],
      'University of Pennsylvania': [0.5, -0.5],
      'Johns Hopkins University': [-0.5, -0.5],
      'Yale University': [0, 2.2],
    };

    // Per-site pin nudge in pixels [x, y] (negative x = west, positive y = south).
    // Lets us shift just the pin without moving the institution logo.
    const pinNudges = {
      'Yale University': [-70, 0],
    };

    // Custom logo sizes: [height, maxWidth] in px
    // Adjust these to make individual logos bigger or smaller
    const logoSizes = {
      'Emory University':                          [100, 140],
      'Johns Hopkins University':                  [70, 140],
      'Northwestern University':                   [100, 100],
      'Oregon Health & Science University':         [90, 100],
      'Rush University':                           [90, 120],
      'University of California, San Francisco (UCSF)': [50, 100],
      'University of Chicago':                     [90, 160],
      'University of Michigan':                    [70, 100],
      'University of Minnesota':                   [90, 160],
      'University of Pennsylvania':                [80, 140],
      'University of Toronto':                     [100, 120],
      'Cornell University':                        [60, 120],
      'Harvard University / MIMIC-IV':             [70, 100],
      'University of Colorado':                    [60, 100],
      'Yale University':                           [40, 180],
    };

    // Add markers
    const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

    // 3D-style red pushpin SVG used for Coming Soon sites
    const pinSvg = `
      <svg viewBox="0 0 30 50" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <radialGradient id="pinDome" cx="38%" cy="32%" r="70%">
            <stop offset="0%" stop-color="#fecaca"/>
            <stop offset="35%" stop-color="#ef4444"/>
            <stop offset="100%" stop-color="#7f1d1d"/>
          </radialGradient>
          <linearGradient id="pinNeck" x1="0%" x2="100%">
            <stop offset="0%" stop-color="#7f1d1d"/>
            <stop offset="50%" stop-color="#dc2626"/>
            <stop offset="100%" stop-color="#7f1d1d"/>
          </linearGradient>
          <linearGradient id="pinDisc" x1="0%" x2="100%">
            <stop offset="0%" stop-color="#991b1b"/>
            <stop offset="50%" stop-color="#dc2626"/>
            <stop offset="100%" stop-color="#7f1d1d"/>
          </linearGradient>
          <linearGradient id="pinNeedle" x1="0%" x2="100%">
            <stop offset="0%" stop-color="#6b7280"/>
            <stop offset="50%" stop-color="#f3f4f6"/>
            <stop offset="100%" stop-color="#374151"/>
          </linearGradient>
        </defs>
        <!-- Needle (silver shaft) -->
        <path d="M13.5 22 L16.5 22 L15.5 47 L14.5 47 Z" fill="url(#pinNeedle)"/>
        <!-- Bottom disc/flange -->
        <ellipse cx="15" cy="22" rx="10" ry="2.5" fill="#7f1d1d"/>
        <ellipse cx="15" cy="20.5" rx="10" ry="2.5" fill="url(#pinDisc)"/>
        <!-- Cylinder neck -->
        <rect x="11" y="11" width="8" height="9.5" fill="url(#pinNeck)"/>
        <!-- Dome head -->
        <ellipse cx="15" cy="11" rx="11" ry="9" fill="url(#pinDome)"/>
        <!-- Dome highlight -->
        <ellipse cx="11" cy="8" rx="3" ry="2" fill="rgba(255,255,255,0.55)"/>
      </svg>`;

    sites.forEach(site => {
      const rawOff = offsets[site.name] || [0, 0];
      const [latOff, lngOff] = [rawOff[0] * offsetScale, rawOff[1] * offsetScale];
      let markerHtml, iconW, iconH, anchor;

      const [baseH, baseW] = logoSizes[site.name] || [70, 140];
      const logoH = Math.round(baseH * sizeScale);
      const logoW = Math.round(baseW * sizeScale);
      const inner = site.logoFile
        ? `<div class="logo-box"><img src="/images/logos/sites/${site.logoFile}" alt="${site.name}" style="height:${logoH}px;max-width:${logoW}px;" /></div>`
        : `<div class="text-fallback">${site.name.charAt(0)}</div>`;

      if (!site.dataReady) {
        // Coming Soon: institution logo with animated red pushpin floating above
        const pinH = Math.round(34 * sizeScale);
        const pinW = Math.round(20 * sizeScale);
        const overlap = Math.round(4 * sizeScale);
        iconW = Math.max(logoW, pinW);
        iconH = pinH + logoH - overlap;
        // Anchor at logo center so the institution sits at the actual lat/lng
        anchor = [iconW / 2, pinH - overlap + logoH / 2];
        const [pinDX, pinDY] = pinNudges[site.name] || [0, 0];
        const pinTransform = (pinDX || pinDY) ? `transform:translate(${pinDX}px, ${pinDY}px);` : '';
        markerHtml = `
          <div class="logo-marker has-pin">
            <div class="pin-icon" style="width:${pinW}px;height:${pinH}px;${pinTransform}">${pinSvg}</div>
            ${inner}
          </div>`;
      } else {
        iconW = logoW;
        iconH = logoH;
        anchor = [logoW / 2, logoH / 2];
        markerHtml = `<div class="logo-marker active">${inner}</div>`;
      }

      const icon = L.divIcon({
        className: 'consortium-logo-marker',
        html: markerHtml,
        iconSize: [iconW, iconH],
        iconAnchor: anchor,
      });

      const marker = L.marker([site.latitude + latOff, site.longitude + lngOff], { icon });
      marker.addTo(map);

      const tooltipContent = createTooltipContent(site);

      if (isTouchDevice) {
        marker.bindPopup(tooltipContent, {
          className: 'consortium-popup',
          maxWidth: 250,
        });
      } else {
        marker.bindTooltip(tooltipContent, {
          direction: 'top',
          offset: [0, -20],
          opacity: 1,
        });
      }
    });

    // NOTE: To adjust the map view, change these two values:
    //   center: [lat, lng]  — where the map is centered
    //   zoom: number        — higher = more zoomed in (try 4.0 to 5.0)

    // Watch for dark mode toggle
    const observer = new MutationObserver(() => {
      if (!map || !tileLayer) return;
      const dark = isDarkMode();
      map.removeLayer(tileLayer);
      tileLayer = L.tileLayer(dark ? DARK_TILES : LIGHT_TILES, {
        attribution: ATTRIBUTION,
        maxZoom: 18,
        subdomains: 'abcd',
      }).addTo(map);
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  }

  // Load Leaflet dynamically
  function loadLeaflet() {
    if (typeof L !== 'undefined') {
      initMap();
      return;
    }

    // Load CSS
    if (!document.querySelector('link[href*="leaflet"]')) {
      const css = document.createElement('link');
      css.rel = 'stylesheet';
      css.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
      document.head.appendChild(css);
    }

    // Load JS
    const script = document.createElement('script');
    script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    script.onload = () => initMap();
    document.head.appendChild(script);
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadLeaflet);
  } else {
    loadLeaflet();
  }
</script>

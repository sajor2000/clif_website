---
interface Column {
  key: string;
  label: string;
  type?: 'text' | 'number' | 'boolean' | 'date';
}

interface Props {
  columns: Column[];
  rows: Record<string, any>[];
  searchable?: boolean;
  tableId?: string;
  emptyMessage?: string;
}

const { columns, rows, searchable = true, tableId = 'portal-table', emptyMessage = 'No data available.' } = Astro.props;
---

<div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 overflow-hidden">
  {searchable && (
    <div class="p-4 border-b border-gray-200 dark:border-neutral-700">
      <input
        type="text"
        id={`search-${tableId}`}
        placeholder="Search..."
        class="w-full md:w-72 px-4 py-2 border border-gray-300 dark:border-neutral-600 rounded-lg text-sm text-gray-900 dark:text-white bg-white dark:bg-neutral-700 focus:outline-none focus:ring-2 focus:ring-clif-burgundy focus:border-transparent"
      />
    </div>
  )}

  {rows.length === 0 ? (
    <div class="p-8 text-center text-gray-500 dark:text-gray-400">{emptyMessage}</div>
  ) : (
    <div class="overflow-x-auto">
      <table class="w-full text-sm" id={tableId}>
        <thead>
          <tr class="bg-gray-50 dark:bg-neutral-700/50">
            {columns.map((col) => (
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider whitespace-nowrap">
                {col.label}
              </th>
            ))}
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-neutral-700">
          {rows.map((row, i) => (
            <tr class={`hover:bg-gray-50 dark:hover:bg-neutral-700/30 transition-colors ${i % 2 === 0 ? '' : 'bg-gray-50/50 dark:bg-neutral-800/50'}`} data-search-row>
              {columns.map((col) => (
                <td class="px-4 py-3 text-gray-900 dark:text-gray-200 whitespace-nowrap">
                  {col.type === 'boolean' ? (
                    row[col.key] ? (
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">Yes</span>
                    ) : (
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 dark:bg-neutral-700 dark:text-gray-400">No</span>
                    )
                  ) : col.type === 'date' ? (
                    row[col.key] ? new Date(row[col.key]).toLocaleDateString() : '—'
                  ) : (
                    row[col.key] ?? '—'
                  )}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <div class="p-3 border-t border-gray-200 dark:border-neutral-700 text-xs text-gray-500 dark:text-gray-400">
    {rows.length} {rows.length === 1 ? 'record' : 'records'}
  </div>
</div>

{searchable && (
  <script is:inline define:vars={{ tableId }}>
    document.addEventListener('DOMContentLoaded', function() {
      var input = document.getElementById('search-' + tableId);
      var table = document.getElementById(tableId);
      if (!input || !table) return;

      input.addEventListener('input', function() {
        var query = this.value.toLowerCase();
        var rows = table.querySelectorAll('[data-search-row]');
        rows.forEach(function(row) {
          var text = row.textContent.toLowerCase();
          row.style.display = text.includes(query) ? '' : 'none';
        });
      });
    });
  </script>
)}

---
import { getDb } from '../../lib/turso';

interface Props {
  currentPath: string;
  isAdmin?: boolean;
}

const { currentPath, isAdmin = false } = Astro.props;

let pendingCount = 0;
if (isAdmin) {
  try {
    const db = getDb();
    const result = await db.execute('SELECT COUNT(*) as cnt FROM users WHERE is_approved = 0');
    pendingCount = Number(result.rows[0]?.cnt) || 0;
  } catch {}
}

const portalItems = [
  { label: 'Dashboard', href: '/portal', icon: 'grid', wip: false },
  { label: 'Site Details', href: '/portal/site-details', icon: 'building', wip: false },
  { label: 'Member Directory', href: '/portal/directory', icon: 'users', wip: false },
  { label: 'Authorship Tool', href: '/portal/authorship', icon: 'document', wip: false },
  { label: 'Status Tracker', href: '/portal/status', icon: 'check-circle', wip: true },
  { label: 'Calendar', href: '/portal/calendar', icon: 'calendar-days', wip: false },
  { label: 'Voting', href: '/portal/voting', icon: 'vote', wip: false },
  { label: 'Secure Masking', href: '/portal/crypto', icon: 'lock', wip: false },
];

function isActive(href: string): boolean {
  if (href === '/portal') return currentPath === '/portal' || currentPath === '/portal/';
  return currentPath.startsWith(href);
}
---

<nav class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 p-4" aria-label="Portal navigation">
  <h2 class="text-xs font-semibold uppercase text-gray-500 dark:text-gray-400 tracking-wider mb-3 px-3">Portal</h2>
  <ul class="space-y-1">
    {portalItems.map((item) => (
      <li>
        <a
          href={item.href}
          class={`flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
            isActive(item.href)
              ? 'bg-clif-burgundy/10 text-clif-burgundy dark:bg-clif-burgundy/20'
              : 'text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-neutral-700'
          }`}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
          {item.wip && (
            <span class="ml-auto text-[10px] font-semibold uppercase tracking-wide bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400 px-1.5 py-0.5 rounded">WIP</span>
          )}
        </a>
      </li>
    ))}
    {isAdmin && (
      <li class="pt-2 mt-2 border-t border-gray-200 dark:border-neutral-700">
        <a
          href="/portal/admin"
          class={`flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
            isActive('/portal/admin')
              ? 'bg-clif-burgundy/10 text-clif-burgundy dark:bg-clif-burgundy/20'
              : 'text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-neutral-700'
          }`}
          aria-current={isActive('/portal/admin') ? 'page' : undefined}
        >
          Admin Panel
          {pendingCount > 0 && (
            <span class="ml-auto inline-flex items-center justify-center w-5 h-5 text-[10px] font-bold text-white bg-red-500 rounded-full">{pendingCount}</span>
          )}
        </a>
      </li>
    )}
  </ul>
</nav>

---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import PortalNav from '../../components/portal/PortalNav.astro';

const profile = Astro.locals.profile;
const supabase = Astro.locals.supabase;

const { data: members, error } = await supabase
  .from('profiles')
  .select('*')
  .eq('is_approved', true)
  .order('full_name');
---

<BaseLayout title="Member Directory">
  <div class="container mx-auto px-4 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <aside class="lg:w-64 shrink-0">
        <PortalNav currentPath={Astro.url.pathname} isAdmin={profile?.role === 'admin'} />
      </aside>

      <div class="flex-1 min-w-0">
        <div class="mb-6">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Member Directory</h1>
          <p class="text-gray-600 dark:text-gray-400 mt-1">Approved consortium members and their contact information</p>
        </div>

        {error ? (
          <div class="bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-lg p-4 text-sm">
            Error loading data: {error.message}
          </div>
        ) : !members || members.length === 0 ? (
          <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 p-8 text-center text-gray-500 dark:text-gray-400">
            No members found.
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            {members.map((member: any) => (
              <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 p-5">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-clif-burgundy/10 dark:bg-clif-burgundy/20 rounded-full flex items-center justify-center">
                    <span class="text-clif-burgundy font-semibold text-sm">
                      {(member.full_name || member.email).charAt(0).toUpperCase()}
                    </span>
                  </div>
                  <div>
                    <h3 class="font-semibold text-gray-900 dark:text-white text-sm">
                      {member.full_name || 'Unknown'}
                    </h3>
                    <p class="text-xs text-gray-500 dark:text-gray-400">{member.email}</p>
                  </div>
                </div>
                {member.institution && (
                  <p class="text-sm text-gray-600 dark:text-gray-400 mt-3">{member.institution}</p>
                )}
                {member.role === 'admin' && (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400 mt-2">
                    Admin
                  </span>
                )}
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>

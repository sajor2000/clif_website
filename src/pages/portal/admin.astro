---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import PortalNav from '../../components/portal/PortalNav.astro';
import { getDb } from '../../lib/turso';

const user = Astro.locals.user;

const db = getDb();
let allProfiles: any[] = [];
let error: string | null = null;

try {
  const result = await db.execute('SELECT * FROM users ORDER BY created_at DESC');
  allProfiles = result.rows.map((row) => ({
    ...row,
    is_approved: Boolean(row.is_approved),
  }));
} catch (e: any) {
  error = e.message;
}

const pendingUsers = allProfiles.filter((p) => !p.is_approved);
const approvedUsers = allProfiles.filter((p) => p.is_approved);

const roleCounts: Record<string, number> = { all: approvedUsers.length, member: 0, steering: 0, admin: 0 };
approvedUsers.forEach((u: any) => { if (u.role in roleCounts) roleCounts[u.role]++; });

// Site assignment data
let sites: any[] = [];
let siteEditors: any[] = [];
try {
  const sitesResult = await db.execute('SELECT id, site_name, institution FROM site_details ORDER BY site_name');
  sites = sitesResult.rows as any[];

  const editorsResult = await db.execute(`
    SELECT se.site_id, se.user_id, se.assigned_at, se.notified_at,
           u.full_name, u.email, u.institution
    FROM site_editors se
    JOIN users u ON se.user_id = u.id
    ORDER BY se.assigned_at DESC
  `);
  siteEditors = editorsResult.rows as any[];
} catch {}
---

<BaseLayout title="Admin Panel">
  <div class="container mx-auto px-4 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <aside class="lg:w-64 shrink-0">
        <PortalNav currentPath={Astro.url.pathname} isAdmin={true} />
      </aside>

      <div class="flex-1 min-w-0">
        <div class="mb-8">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Admin Panel</h1>
          <p class="text-gray-600 dark:text-gray-400 mt-1">Manage user accounts and approvals</p>
        </div>

        {error && (
          <div class="bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-lg p-4 text-sm mb-6">
            Error loading profiles: {error}
          </div>
        )}

        <!-- Pending Approvals -->
        <div class="mb-8">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
            Pending Approvals
            {pendingUsers.length > 0 && (
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400">
                {pendingUsers.length}
              </span>
            )}
          </h2>

          {pendingUsers.length === 0 ? (
            <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 p-6 text-center text-gray-500 dark:text-gray-400 text-sm">
              No pending approvals.
            </div>
          ) : (
            <div class="space-y-3">
              {pendingUsers.map((u: any) => (
                <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-yellow-200 dark:border-yellow-900/50 p-5 flex items-center justify-between gap-4" data-user-card={u.id}>
                  <div>
                    <p class="font-semibold text-gray-900 dark:text-white">{u.full_name || 'No name'}</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400">{u.email}</p>
                    {u.institution && <p class="text-sm text-gray-500 dark:text-gray-400">{u.institution}</p>}
                    <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Requested {new Date(u.created_at).toLocaleDateString()}</p>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <button
                      class="approve-btn px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg transition-colors"
                      data-user-id={u.id}
                    >
                      Approve
                    </button>
                    <button
                      class="reject-btn px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors"
                      data-user-id={u.id}
                    >
                      Reject
                    </button>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Approved Members -->
        <div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4" id="approved-heading">
            Approved Members (<span id="approved-count">{approvedUsers.length}</span>)
          </h2>

          <div class="flex flex-wrap gap-2 mb-4" id="role-filters">
            {['all', 'member', 'steering', 'admin'].map((role) => (
              <button
                class={`role-filter-btn px-3 py-1.5 text-xs font-medium rounded-full transition-colors ${role === 'all' ? 'bg-clif-burgundy text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-neutral-700 dark:text-gray-300 dark:hover:bg-neutral-600'}`}
                data-filter-role={role}
              >
                {role.charAt(0).toUpperCase() + role.slice(1)} ({roleCounts[role]})
              </button>
            ))}
          </div>

          {approvedUsers.length === 0 ? (
            <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 p-6 text-center text-gray-500 dark:text-gray-400 text-sm">
              No approved members yet.
            </div>
          ) : (
            <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 overflow-hidden">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-gray-50 dark:bg-neutral-700/50">
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase">Name</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase">Email</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase">Institution</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase">Role</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase">Joined</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase"></th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-neutral-700">
                  {approvedUsers.map((u: any, i: number) => (
                    <>
                      <tr class={i % 2 === 0 ? '' : 'bg-gray-50/50 dark:bg-neutral-800/50'} data-role={u.role}>
                        <td class="px-4 py-3 text-gray-900 dark:text-gray-200">
                          <span class="user-display-name" data-user-id={u.id}>{u.full_name || '\u2014'}</span>
                          <input type="text" class="user-edit-name hidden w-full text-xs px-2 py-1 border border-gray-300 dark:border-neutral-600 rounded bg-white dark:bg-neutral-700 text-gray-900 dark:text-white" data-user-id={u.id} value={u.full_name || ''} placeholder="Full name" />
                        </td>
                        <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{u.email}</td>
                        <td class="px-4 py-3 text-gray-600 dark:text-gray-400">
                          <span class="user-display-institution" data-user-id={u.id}>{u.institution || '\u2014'}</span>
                          <input type="text" class="user-edit-institution hidden w-full text-xs px-2 py-1 border border-gray-300 dark:border-neutral-600 rounded bg-white dark:bg-neutral-700 text-gray-900 dark:text-white" data-user-id={u.id} value={u.institution || ''} placeholder="Institution" />
                        </td>
                        <td class="px-4 py-3">
                          <select
                            class="role-select text-xs rounded-lg border border-gray-300 dark:border-neutral-600 bg-white dark:bg-neutral-700 text-gray-900 dark:text-white px-2 py-1"
                            data-user-id={u.id}
                            data-current-role={u.role}
                          >
                            <option value="member" selected={u.role === 'member'}>member</option>
                            <option value="steering" selected={u.role === 'steering'}>steering</option>
                            <option value="admin" selected={u.role === 'admin'}>admin</option>
                          </select>
                        </td>
                        <td class="px-4 py-3 text-gray-500 dark:text-gray-400 text-xs">{new Date(u.created_at).toLocaleDateString()}</td>
                        <td class="px-4 py-3 space-x-2 whitespace-nowrap">
                          <button
                            class="edit-member-btn text-xs text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 underline"
                            data-user-id={u.id}
                          >
                            Edit
                          </button>
                          <button
                            class="save-member-btn hidden text-xs text-green-600 hover:text-green-800 dark:text-green-400 dark:hover:text-green-300 underline"
                            data-user-id={u.id}
                          >
                            Save
                          </button>
                          <button
                            class="cancel-edit-btn hidden text-xs text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 underline"
                            data-user-id={u.id}
                          >
                            Cancel
                          </button>
                          <button
                            class="details-toggle-btn text-xs text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 underline"
                            data-user-id={u.id}
                          >
                            Details
                          </button>
                          {u.id !== user!.id && (
                            <button
                              class="remove-member-btn text-xs text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 underline"
                              data-user-id={u.id}
                              data-user-name={u.full_name || u.email}
                            >
                              Remove
                            </button>
                          )}
                        </td>
                      </tr>
                      <tr class="details-row hidden bg-gray-50 dark:bg-neutral-900/40" data-user-id={u.id} data-role={u.role}>
                        <td colspan="6" class="px-4 py-4">
                          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
                            <label class="block">
                              <span class="block text-gray-600 dark:text-gray-400 mb-1">Degrees</span>
                              <input type="text" class="details-input w-full px-2 py-1 border border-gray-300 dark:border-neutral-600 rounded bg-white dark:bg-neutral-700 text-gray-900 dark:text-white" data-field="degrees" value={u.degrees || ''} placeholder="e.g. MD, MS" />
                            </label>
                            <label class="block md:col-span-2">
                              <span class="block text-gray-600 dark:text-gray-400 mb-1">Affiliation</span>
                              <textarea rows="2" class="details-input w-full px-2 py-1 border border-gray-300 dark:border-neutral-600 rounded bg-white dark:bg-neutral-700 text-gray-900 dark:text-white" data-field="affiliation" placeholder="Lab / department / institution (long form)">{u.affiliation || ''}</textarea>
                            </label>
                            <label class="block">
                              <span class="block text-gray-600 dark:text-gray-400 mb-1">ORCID</span>
                              <input type="text" class="details-input w-full px-2 py-1 border border-gray-300 dark:border-neutral-600 rounded bg-white dark:bg-neutral-700 text-gray-900 dark:text-white" data-field="orcid" value={u.orcid || ''} placeholder="0000-0000-0000-0000" />
                            </label>
                            <label class="block">
                              <span class="block text-gray-600 dark:text-gray-400 mb-1">GitHub username</span>
                              <input type="text" class="details-input w-full px-2 py-1 border border-gray-300 dark:border-neutral-600 rounded bg-white dark:bg-neutral-700 text-gray-900 dark:text-white" data-field="github_username" value={u.github_username || ''} placeholder="octocat" />
                            </label>
                            <label class="block">
                              <span class="block text-gray-600 dark:text-gray-400 mb-1">Work email</span>
                              <input type="email" class="details-input w-full px-2 py-1 border border-gray-300 dark:border-neutral-600 rounded bg-white dark:bg-neutral-700 text-gray-900 dark:text-white" data-field="work_email" value={u.work_email || ''} placeholder={u.email || 'name@institution.edu'} />
                            </label>
                            <label class="block">
                              <span class="block text-gray-600 dark:text-gray-400 mb-1">Personal Gmail</span>
                              <input type="email" class="details-input w-full px-2 py-1 border border-gray-300 dark:border-neutral-600 rounded bg-white dark:bg-neutral-700 text-gray-900 dark:text-white" data-field="gmail_personal" value={u.gmail_personal || ''} placeholder="name@gmail.com" />
                            </label>
                            <label class="block md:col-span-2">
                              <span class="block text-gray-600 dark:text-gray-400 mb-1">Funding</span>
                              <textarea rows="2" class="details-input w-full px-2 py-1 border border-gray-300 dark:border-neutral-600 rounded bg-white dark:bg-neutral-700 text-gray-900 dark:text-white" data-field="funding" placeholder="Grants and other funding sources">{u.funding || ''}</textarea>
                            </label>
                            <label class="block md:col-span-2">
                              <span class="block text-gray-600 dark:text-gray-400 mb-1">Conflicts of Interest</span>
                              <textarea rows="2" class="details-input w-full px-2 py-1 border border-gray-300 dark:border-neutral-600 rounded bg-white dark:bg-neutral-700 text-gray-900 dark:text-white" data-field="conflicts_of_interest" placeholder="Disclosed conflicts">{u.conflicts_of_interest || ''}</textarea>
                            </label>
                          </div>
                          <div class="flex items-center gap-3 mt-3">
                            <button class="details-save-btn px-3 py-1.5 text-xs font-medium text-white bg-clif-burgundy hover:bg-clif-burgundy/90 rounded" data-user-id={u.id}>Save details</button>
                            <button class="details-cancel-btn text-xs text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 underline" data-user-id={u.id}>Close</button>
                            <span class="details-status text-xs" data-user-id={u.id}></span>
                          </div>
                        </td>
                      </tr>
                    </>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>

        {/* ============ Site Editor Assignments ============ */}
        <div class="mt-8">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Site Editor Assignments</h2>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Assign members to review and update their site's details. You can also send email notifications.</p>

          {sites.length === 0 ? (
            <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 p-6 text-center text-gray-500 dark:text-gray-400 text-sm">
              No sites available. Run the seed script first.
            </div>
          ) : (
            <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 p-5">
              {/* Site selector */}
              <div class="flex flex-col sm:flex-row gap-3 mb-4">
                <div class="flex-1">
                  <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Select Site</label>
                  <select id="site-selector" class="w-full text-sm px-3 py-2 border border-gray-300 dark:border-neutral-600 rounded-lg bg-white dark:bg-neutral-700 text-gray-900 dark:text-white">
                    <option value="">Choose a site...</option>
                    {sites.map((s: any) => (
                      <option value={s.id} data-institution={s.institution || ''}>{s.site_name}{s.institution && s.institution !== s.site_name ? ` (${s.institution})` : ''}</option>
                    ))}
                  </select>
                </div>
              </div>

              {/* Current editors for selected site */}
              <div id="site-editors-panel" class="hidden">
                <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Assigned Editors</h3>
                <div id="site-editors-list" class="space-y-2 mb-4">
                  <p class="text-sm text-gray-500 dark:text-gray-400">No editors assigned.</p>
                </div>

                {/* Assign new editor */}
                <div class="border-t border-gray-100 dark:border-neutral-700 pt-3 mt-3">
                  <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Assign New Editor</h3>
                  <div class="flex gap-2">
                    <select id="user-selector" class="flex-1 text-sm px-3 py-2 border border-gray-300 dark:border-neutral-600 rounded-lg bg-white dark:bg-neutral-700 text-gray-900 dark:text-white">
                      <option value="">Choose a member...</option>
                      {approvedUsers.map((u: any) => (
                        <option value={u.id} data-institution={u.institution || ''}>{u.full_name || u.email} — {u.institution || 'No institution'}</option>
                      ))}
                    </select>
                    <button id="assign-editor-btn" class="px-4 py-2 text-sm font-medium text-white bg-clif-burgundy hover:bg-clif-burgundy/90 rounded-lg transition-colors whitespace-nowrap">
                      Assign
                    </button>
                  </div>
                  <div id="assign-status" class="text-sm mt-2 hidden"></div>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  {/* Pass site editors data to client JS */}
  <script is:inline define:vars={{ siteEditorsJson: JSON.stringify(siteEditors) }}>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.approve-btn').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var userId = this.getAttribute('data-user-id');
          if (!confirm('Approve this user?')) return;
          this.disabled = true;
          this.textContent = 'Approving...';

          var res = await fetch('/api/admin/approve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: userId }),
          });

          if (res.ok) {
            var card = document.querySelector('[data-user-card="' + userId + '"]');
            if (card) card.remove();
          } else {
            alert('Failed to approve user');
            this.disabled = false;
            this.textContent = 'Approve';
          }
        });
      });

      document.querySelectorAll('.role-select').forEach(function(sel) {
        sel.addEventListener('change', async function() {
          var userId = this.getAttribute('data-user-id');
          var newRole = this.value;
          var prev = this.getAttribute('data-current-role');
          if (!confirm('Change role to ' + newRole + '?')) {
            this.value = prev;
            return;
          }
          var res = await fetch('/api/admin/set-role', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: userId, role: newRole }),
          });
          if (res.ok) {
            this.setAttribute('data-current-role', newRole);
          } else {
            var data = await res.json();
            alert(data.error || 'Failed to update role');
            this.value = prev;
          }
        });
      });

      // Edit member inline
      document.querySelectorAll('.edit-member-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var uid = this.getAttribute('data-user-id');
          this.classList.add('hidden');
          document.querySelector('.save-member-btn[data-user-id="' + uid + '"]').classList.remove('hidden');
          document.querySelector('.cancel-edit-btn[data-user-id="' + uid + '"]').classList.remove('hidden');
          document.querySelector('.user-display-name[data-user-id="' + uid + '"]').classList.add('hidden');
          document.querySelector('.user-edit-name[data-user-id="' + uid + '"]').classList.remove('hidden');
          document.querySelector('.user-display-institution[data-user-id="' + uid + '"]').classList.add('hidden');
          document.querySelector('.user-edit-institution[data-user-id="' + uid + '"]').classList.remove('hidden');
        });
      });

      document.querySelectorAll('.cancel-edit-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var uid = this.getAttribute('data-user-id');
          this.classList.add('hidden');
          document.querySelector('.save-member-btn[data-user-id="' + uid + '"]').classList.add('hidden');
          document.querySelector('.edit-member-btn[data-user-id="' + uid + '"]').classList.remove('hidden');
          document.querySelector('.user-display-name[data-user-id="' + uid + '"]').classList.remove('hidden');
          document.querySelector('.user-edit-name[data-user-id="' + uid + '"]').classList.add('hidden');
          document.querySelector('.user-display-institution[data-user-id="' + uid + '"]').classList.remove('hidden');
          document.querySelector('.user-edit-institution[data-user-id="' + uid + '"]').classList.add('hidden');
        });
      });

      document.querySelectorAll('.save-member-btn').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var uid = this.getAttribute('data-user-id');
          var nameInput = document.querySelector('.user-edit-name[data-user-id="' + uid + '"]');
          var instInput = document.querySelector('.user-edit-institution[data-user-id="' + uid + '"]');
          this.disabled = true;
          this.textContent = 'Saving...';

          var res = await fetch('/api/admin/update-user', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: uid, full_name: nameInput.value.trim(), institution: instInput.value.trim() }),
          });

          if (res.ok) {
            window.location.reload();
          } else {
            alert('Failed to update user');
            this.disabled = false;
            this.textContent = 'Save';
          }
        });
      });

      // Toggle the per-user details edit row
      document.querySelectorAll('.details-toggle-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var uid = this.getAttribute('data-user-id');
          var row = document.querySelector('.details-row[data-user-id="' + uid + '"]');
          if (row) row.classList.toggle('hidden');
        });
      });

      document.querySelectorAll('.details-cancel-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var uid = this.getAttribute('data-user-id');
          var row = document.querySelector('.details-row[data-user-id="' + uid + '"]');
          if (row) row.classList.add('hidden');
        });
      });

      document.querySelectorAll('.details-save-btn').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var uid = this.getAttribute('data-user-id');
          var row = document.querySelector('.details-row[data-user-id="' + uid + '"]');
          if (!row) return;
          var status = row.querySelector('.details-status');
          var payload = { userId: uid };
          row.querySelectorAll('.details-input').forEach(function(el) {
            payload[el.getAttribute('data-field')] = el.value;
          });

          this.disabled = true;
          this.textContent = 'Saving…';
          if (status) { status.textContent = ''; status.className = 'details-status text-xs'; }

          var res = await fetch('/api/admin/update-user', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          this.disabled = false;
          this.textContent = 'Save details';

          if (res.ok) {
            if (status) {
              status.textContent = 'Saved.';
              status.className = 'details-status text-xs text-green-600 dark:text-green-400';
            }
          } else {
            var data = await res.json().catch(function() { return {}; });
            if (status) {
              status.textContent = data.error || 'Failed to save details';
              status.className = 'details-status text-xs text-red-600 dark:text-red-400';
            }
          }
        });
      });

      document.querySelectorAll('.remove-member-btn').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var userId = this.getAttribute('data-user-id');
          var userName = this.getAttribute('data-user-name');
          if (!confirm('Remove ' + userName + ' from the consortium? This will delete their account and all votes.')) return;
          this.disabled = true;
          this.textContent = 'Removing...';

          var res = await fetch('/api/admin/reject', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: userId }),
          });

          if (res.ok) {
            window.location.reload();
          } else {
            alert('Failed to remove member');
            this.disabled = false;
            this.textContent = 'Remove';
          }
        });
      });

      // Role filter
      document.querySelectorAll('.role-filter-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var role = this.getAttribute('data-filter-role');
          // Update active button styles
          document.querySelectorAll('.role-filter-btn').forEach(function(b) {
            b.classList.remove('bg-clif-burgundy', 'text-white');
            b.classList.add('bg-gray-100', 'text-gray-600', 'hover:bg-gray-200', 'dark:bg-neutral-700', 'dark:text-gray-300', 'dark:hover:bg-neutral-600');
          });
          this.classList.add('bg-clif-burgundy', 'text-white');
          this.classList.remove('bg-gray-100', 'text-gray-600', 'hover:bg-gray-200', 'dark:bg-neutral-700', 'dark:text-gray-300', 'dark:hover:bg-neutral-600');
          // Filter rows — only operate on the user rows; collapse any open details.
          var userRows = document.querySelectorAll('tbody tr[data-role]:not(.details-row)');
          var visibleCount = 0;
          userRows.forEach(function(row) {
            var uid = row.querySelector('[data-user-id]') ? row.querySelector('[data-user-id]').getAttribute('data-user-id') : null;
            var detailsRow = uid ? document.querySelector('.details-row[data-user-id="' + uid + '"]') : null;
            if (role === 'all' || row.getAttribute('data-role') === role) {
              row.classList.remove('hidden');
              visibleCount++;
            } else {
              row.classList.add('hidden');
              if (detailsRow) detailsRow.classList.add('hidden');
            }
          });
          document.getElementById('approved-count').textContent = visibleCount;
        });
      });

      document.querySelectorAll('.reject-btn').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var userId = this.getAttribute('data-user-id');
          if (!confirm('Reject and delete this user? This cannot be undone.')) return;
          this.disabled = true;
          this.textContent = 'Rejecting...';

          var res = await fetch('/api/admin/reject', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: userId }),
          });

          if (res.ok) {
            var card = document.querySelector('[data-user-card="' + userId + '"]');
            if (card) card.remove();
          } else {
            alert('Failed to reject user');
            this.disabled = false;
            this.textContent = 'Reject';
          }
        });
      });

      // ========== Site Editor Assignments ==========
      var allEditors = JSON.parse(siteEditorsJson);
      var siteSelector = document.getElementById('site-selector');
      var editorsPanel = document.getElementById('site-editors-panel');
      var editorsList = document.getElementById('site-editors-list');
      var userSelector = document.getElementById('user-selector');
      var assignBtn = document.getElementById('assign-editor-btn');
      var assignStatus = document.getElementById('assign-status');

      function renderEditors(siteId) {
        if (!editorsList) return;
        var editors = allEditors.filter(function(e) { return e.site_id === siteId; });
        if (editors.length === 0) {
          editorsList.innerHTML = '<p class="text-sm text-gray-500 dark:text-gray-400 italic">No editors assigned yet.</p>';
          return;
        }
        var html = '';
        editors.forEach(function(e) {
          var notifiedBadge = e.notified_at
            ? '<span class="text-xs text-green-600 dark:text-green-400">Notified ' + new Date(e.notified_at).toLocaleDateString() + '</span>'
            : '<button class="notify-editor-btn text-xs text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 underline" data-site-id="' + siteId + '" data-user-id="' + e.user_id + '">Send Notification</button>';

          html += '<div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-neutral-700/50 rounded-lg">'
            + '<div>'
            + '<p class="text-sm font-medium text-gray-900 dark:text-white">' + (e.full_name || e.email) + '</p>'
            + '<p class="text-xs text-gray-500 dark:text-gray-400">' + (e.email || '') + ' &middot; ' + (e.institution || '') + '</p>'
            + '<p class="text-xs text-gray-400 dark:text-gray-500">Assigned ' + new Date(e.assigned_at).toLocaleDateString() + '</p>'
            + '</div>'
            + '<div class="flex items-center gap-3">'
            + notifiedBadge
            + ' <button class="remove-editor-btn text-xs text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 underline" data-site-id="' + siteId + '" data-user-id="' + e.user_id + '">Remove</button>'
            + '</div>'
            + '</div>';
        });
        editorsList.innerHTML = html;

        // Bind remove buttons
        editorsList.querySelectorAll('.remove-editor-btn').forEach(function(btn) {
          btn.addEventListener('click', async function() {
            var sid = this.getAttribute('data-site-id');
            var uid = this.getAttribute('data-user-id');
            if (!confirm('Remove this editor assignment?')) return;
            this.textContent = 'Removing...';
            var res = await fetch('/api/admin/remove-site-editor', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ siteId: sid, userId: uid }),
            });
            if (res.ok) {
              allEditors = allEditors.filter(function(e) { return !(e.site_id === sid && e.user_id === uid); });
              renderEditors(sid);
            } else {
              alert('Failed to remove editor');
            }
          });
        });

        // Bind notify buttons
        editorsList.querySelectorAll('.notify-editor-btn').forEach(function(btn) {
          btn.addEventListener('click', async function() {
            var sid = this.getAttribute('data-site-id');
            var uid = this.getAttribute('data-user-id');
            this.textContent = 'Sending...';
            this.disabled = true;
            var res = await fetch('/api/admin/notify-site-editor', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ siteId: sid, userId: uid }),
            });
            if (res.ok) {
              // Update local data
              allEditors.forEach(function(e) {
                if (e.site_id === sid && e.user_id === uid) {
                  e.notified_at = new Date().toISOString();
                }
              });
              renderEditors(sid);
            } else {
              var data = await res.json();
              alert(data.error || 'Failed to send notification');
              this.textContent = 'Send Notification';
              this.disabled = false;
            }
          });
        });
      }

      if (siteSelector) {
        siteSelector.addEventListener('change', function() {
          var siteId = this.value;
          if (!siteId) {
            if (editorsPanel) editorsPanel.classList.add('hidden');
            return;
          }
          if (editorsPanel) editorsPanel.classList.remove('hidden');

          // Filter user selector: show matching institution first, hide others
          var selectedOption = this.options[this.selectedIndex];
          var siteInstitution = selectedOption.getAttribute('data-institution') || '';
          if (userSelector && siteInstitution) {
            var options = Array.from(userSelector.options).slice(1); // skip placeholder
            options.sort(function(a, b) {
              var aMatch = a.getAttribute('data-institution') === siteInstitution ? 0 : 1;
              var bMatch = b.getAttribute('data-institution') === siteInstitution ? 0 : 1;
              if (aMatch !== bMatch) return aMatch - bMatch;
              return (a.textContent || '').localeCompare(b.textContent || '');
            });
            options.forEach(function(opt) {
              userSelector.appendChild(opt);
              opt.classList.toggle('hidden', opt.getAttribute('data-institution') !== siteInstitution);
            });
            userSelector.value = '';
          }

          renderEditors(siteId);
          if (assignStatus) assignStatus.classList.add('hidden');
        });
      }

      if (assignBtn) {
        assignBtn.addEventListener('click', async function() {
          var siteId = siteSelector ? siteSelector.value : '';
          var userId = userSelector ? userSelector.value : '';
          if (!siteId || !userId) {
            if (assignStatus) {
              assignStatus.textContent = 'Please select both a site and a member.';
              assignStatus.className = 'text-sm mt-2 text-red-600 dark:text-red-400';
              assignStatus.classList.remove('hidden');
            }
            return;
          }

          this.disabled = true;
          this.textContent = 'Assigning...';
          if (assignStatus) assignStatus.classList.add('hidden');

          var res = await fetch('/api/admin/assign-site-editor', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ siteId: siteId, userId: userId }),
          });

          if (res.ok) {
            var data = await res.json();
            if (data.alreadyAssigned) {
              if (assignStatus) {
                assignStatus.textContent = 'This member is already assigned to this site.';
                assignStatus.className = 'text-sm mt-2 text-amber-600 dark:text-amber-400';
                assignStatus.classList.remove('hidden');
              }
            } else {
              // Add to local data
              var userOpt = userSelector.options[userSelector.selectedIndex];
              var parts = userOpt.textContent.split(' — ');
              allEditors.push({
                site_id: siteId,
                user_id: userId,
                full_name: parts[0],
                email: '',
                institution: parts[1] || '',
                assigned_at: new Date().toISOString(),
                notified_at: null,
              });
              renderEditors(siteId);
              if (assignStatus) {
                assignStatus.textContent = 'Editor assigned successfully.';
                assignStatus.className = 'text-sm mt-2 text-green-600 dark:text-green-400';
                assignStatus.classList.remove('hidden');
              }
            }
          } else {
            var errData = await res.json();
            if (assignStatus) {
              assignStatus.textContent = errData.error || 'Failed to assign editor';
              assignStatus.className = 'text-sm mt-2 text-red-600 dark:text-red-400';
              assignStatus.classList.remove('hidden');
            }
          }

          this.disabled = false;
          this.textContent = 'Assign';
          if (userSelector) userSelector.value = '';
        });
      }
    });
  </script>
</BaseLayout>

---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import PortalNav from '../../components/portal/PortalNav.astro';
import { getDb } from '../../lib/turso';

const user = Astro.locals.user;

const db = getDb();
let allProfiles: any[] = [];
let error: string | null = null;

try {
  const result = await db.execute('SELECT * FROM users ORDER BY created_at DESC');
  allProfiles = result.rows.map((row) => ({
    ...row,
    is_approved: Boolean(row.is_approved),
  }));
} catch (e: any) {
  error = e.message;
}

const pendingUsers = allProfiles.filter((p) => !p.is_approved);
const approvedUsers = allProfiles.filter((p) => p.is_approved);

const roleCounts: Record<string, number> = { all: approvedUsers.length, member: 0, steering: 0, admin: 0 };
approvedUsers.forEach((u: any) => { if (u.role in roleCounts) roleCounts[u.role]++; });
---

<BaseLayout title="Admin Panel">
  <div class="container mx-auto px-4 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <aside class="lg:w-64 shrink-0">
        <PortalNav currentPath={Astro.url.pathname} isAdmin={true} />
      </aside>

      <div class="flex-1 min-w-0">
        <div class="mb-8">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Admin Panel</h1>
          <p class="text-gray-600 dark:text-gray-400 mt-1">Manage user accounts and approvals</p>
        </div>

        {error && (
          <div class="bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-lg p-4 text-sm mb-6">
            Error loading profiles: {error}
          </div>
        )}

        <!-- Pending Approvals -->
        <div class="mb-8">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
            Pending Approvals
            {pendingUsers.length > 0 && (
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400">
                {pendingUsers.length}
              </span>
            )}
          </h2>

          {pendingUsers.length === 0 ? (
            <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 p-6 text-center text-gray-500 dark:text-gray-400 text-sm">
              No pending approvals.
            </div>
          ) : (
            <div class="space-y-3">
              {pendingUsers.map((u: any) => (
                <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-yellow-200 dark:border-yellow-900/50 p-5 flex items-center justify-between gap-4" data-user-card={u.id}>
                  <div>
                    <p class="font-semibold text-gray-900 dark:text-white">{u.full_name || 'No name'}</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400">{u.email}</p>
                    {u.institution && <p class="text-sm text-gray-500 dark:text-gray-400">{u.institution}</p>}
                    <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Requested {new Date(u.created_at).toLocaleDateString()}</p>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <button
                      class="approve-btn px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg transition-colors"
                      data-user-id={u.id}
                    >
                      Approve
                    </button>
                    <button
                      class="reject-btn px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors"
                      data-user-id={u.id}
                    >
                      Reject
                    </button>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Approved Members -->
        <div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4" id="approved-heading">
            Approved Members (<span id="approved-count">{approvedUsers.length}</span>)
          </h2>

          <div class="flex flex-wrap gap-2 mb-4" id="role-filters">
            {['all', 'member', 'steering', 'admin'].map((role) => (
              <button
                class={`role-filter-btn px-3 py-1.5 text-xs font-medium rounded-full transition-colors ${role === 'all' ? 'bg-clif-burgundy text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-neutral-700 dark:text-gray-300 dark:hover:bg-neutral-600'}`}
                data-filter-role={role}
              >
                {role.charAt(0).toUpperCase() + role.slice(1)} ({roleCounts[role]})
              </button>
            ))}
          </div>

          {approvedUsers.length === 0 ? (
            <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 p-6 text-center text-gray-500 dark:text-gray-400 text-sm">
              No approved members yet.
            </div>
          ) : (
            <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 overflow-hidden">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-gray-50 dark:bg-neutral-700/50">
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase">Name</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase">Email</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase">Institution</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase">Role</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase">Joined</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase"></th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-neutral-700">
                  {approvedUsers.map((u: any, i: number) => (
                    <tr class={i % 2 === 0 ? '' : 'bg-gray-50/50 dark:bg-neutral-800/50'} data-role={u.role}>
                      <td class="px-4 py-3 text-gray-900 dark:text-gray-200">
                        <span class="user-display-name" data-user-id={u.id}>{u.full_name || '\u2014'}</span>
                        <input type="text" class="user-edit-name hidden w-full text-xs px-2 py-1 border border-gray-300 dark:border-neutral-600 rounded bg-white dark:bg-neutral-700 text-gray-900 dark:text-white" data-user-id={u.id} value={u.full_name || ''} placeholder="Full name" />
                      </td>
                      <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{u.email}</td>
                      <td class="px-4 py-3 text-gray-600 dark:text-gray-400">
                        <span class="user-display-institution" data-user-id={u.id}>{u.institution || '\u2014'}</span>
                        <input type="text" class="user-edit-institution hidden w-full text-xs px-2 py-1 border border-gray-300 dark:border-neutral-600 rounded bg-white dark:bg-neutral-700 text-gray-900 dark:text-white" data-user-id={u.id} value={u.institution || ''} placeholder="Institution" />
                      </td>
                      <td class="px-4 py-3">
                        <select
                          class="role-select text-xs rounded-lg border border-gray-300 dark:border-neutral-600 bg-white dark:bg-neutral-700 text-gray-900 dark:text-white px-2 py-1"
                          data-user-id={u.id}
                          data-current-role={u.role}
                        >
                          <option value="member" selected={u.role === 'member'}>member</option>
                          <option value="steering" selected={u.role === 'steering'}>steering</option>
                          <option value="admin" selected={u.role === 'admin'}>admin</option>
                        </select>
                      </td>
                      <td class="px-4 py-3 text-gray-500 dark:text-gray-400 text-xs">{new Date(u.created_at).toLocaleDateString()}</td>
                      <td class="px-4 py-3 space-x-2 whitespace-nowrap">
                        <button
                          class="edit-member-btn text-xs text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 underline"
                          data-user-id={u.id}
                        >
                          Edit
                        </button>
                        <button
                          class="save-member-btn hidden text-xs text-green-600 hover:text-green-800 dark:text-green-400 dark:hover:text-green-300 underline"
                          data-user-id={u.id}
                        >
                          Save
                        </button>
                        <button
                          class="cancel-edit-btn hidden text-xs text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 underline"
                          data-user-id={u.id}
                        >
                          Cancel
                        </button>
                        {u.id !== user!.id && (
                          <button
                            class="remove-member-btn text-xs text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 underline"
                            data-user-id={u.id}
                            data-user-name={u.full_name || u.email}
                          >
                            Remove
                          </button>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.approve-btn').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var userId = this.getAttribute('data-user-id');
          if (!confirm('Approve this user?')) return;
          this.disabled = true;
          this.textContent = 'Approving...';

          var res = await fetch('/api/admin/approve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: userId }),
          });

          if (res.ok) {
            var card = document.querySelector('[data-user-card="' + userId + '"]');
            if (card) card.remove();
          } else {
            alert('Failed to approve user');
            this.disabled = false;
            this.textContent = 'Approve';
          }
        });
      });

      document.querySelectorAll('.role-select').forEach(function(sel) {
        sel.addEventListener('change', async function() {
          var userId = this.getAttribute('data-user-id');
          var newRole = this.value;
          var prev = this.getAttribute('data-current-role');
          if (!confirm('Change role to ' + newRole + '?')) {
            this.value = prev;
            return;
          }
          var res = await fetch('/api/admin/set-role', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: userId, role: newRole }),
          });
          if (res.ok) {
            this.setAttribute('data-current-role', newRole);
          } else {
            var data = await res.json();
            alert(data.error || 'Failed to update role');
            this.value = prev;
          }
        });
      });

      // Edit member inline
      document.querySelectorAll('.edit-member-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var uid = this.getAttribute('data-user-id');
          this.classList.add('hidden');
          document.querySelector('.save-member-btn[data-user-id="' + uid + '"]').classList.remove('hidden');
          document.querySelector('.cancel-edit-btn[data-user-id="' + uid + '"]').classList.remove('hidden');
          document.querySelector('.user-display-name[data-user-id="' + uid + '"]').classList.add('hidden');
          document.querySelector('.user-edit-name[data-user-id="' + uid + '"]').classList.remove('hidden');
          document.querySelector('.user-display-institution[data-user-id="' + uid + '"]').classList.add('hidden');
          document.querySelector('.user-edit-institution[data-user-id="' + uid + '"]').classList.remove('hidden');
        });
      });

      document.querySelectorAll('.cancel-edit-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var uid = this.getAttribute('data-user-id');
          this.classList.add('hidden');
          document.querySelector('.save-member-btn[data-user-id="' + uid + '"]').classList.add('hidden');
          document.querySelector('.edit-member-btn[data-user-id="' + uid + '"]').classList.remove('hidden');
          document.querySelector('.user-display-name[data-user-id="' + uid + '"]').classList.remove('hidden');
          document.querySelector('.user-edit-name[data-user-id="' + uid + '"]').classList.add('hidden');
          document.querySelector('.user-display-institution[data-user-id="' + uid + '"]').classList.remove('hidden');
          document.querySelector('.user-edit-institution[data-user-id="' + uid + '"]').classList.add('hidden');
        });
      });

      document.querySelectorAll('.save-member-btn').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var uid = this.getAttribute('data-user-id');
          var nameInput = document.querySelector('.user-edit-name[data-user-id="' + uid + '"]');
          var instInput = document.querySelector('.user-edit-institution[data-user-id="' + uid + '"]');
          this.disabled = true;
          this.textContent = 'Saving...';

          var res = await fetch('/api/admin/update-user', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: uid, full_name: nameInput.value.trim(), institution: instInput.value.trim() }),
          });

          if (res.ok) {
            window.location.reload();
          } else {
            alert('Failed to update user');
            this.disabled = false;
            this.textContent = 'Save';
          }
        });
      });

      document.querySelectorAll('.remove-member-btn').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var userId = this.getAttribute('data-user-id');
          var userName = this.getAttribute('data-user-name');
          if (!confirm('Remove ' + userName + ' from the consortium? This will delete their account and all votes.')) return;
          this.disabled = true;
          this.textContent = 'Removing...';

          var res = await fetch('/api/admin/reject', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: userId }),
          });

          if (res.ok) {
            window.location.reload();
          } else {
            alert('Failed to remove member');
            this.disabled = false;
            this.textContent = 'Remove';
          }
        });
      });

      // Role filter
      document.querySelectorAll('.role-filter-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var role = this.getAttribute('data-filter-role');
          // Update active button styles
          document.querySelectorAll('.role-filter-btn').forEach(function(b) {
            b.classList.remove('bg-clif-burgundy', 'text-white');
            b.classList.add('bg-gray-100', 'text-gray-600', 'hover:bg-gray-200', 'dark:bg-neutral-700', 'dark:text-gray-300', 'dark:hover:bg-neutral-600');
          });
          this.classList.add('bg-clif-burgundy', 'text-white');
          this.classList.remove('bg-gray-100', 'text-gray-600', 'hover:bg-gray-200', 'dark:bg-neutral-700', 'dark:text-gray-300', 'dark:hover:bg-neutral-600');
          // Filter rows
          var rows = document.querySelectorAll('tbody tr[data-role]');
          var visibleCount = 0;
          rows.forEach(function(row) {
            if (role === 'all' || row.getAttribute('data-role') === role) {
              row.classList.remove('hidden');
              visibleCount++;
            } else {
              row.classList.add('hidden');
            }
          });
          document.getElementById('approved-count').textContent = visibleCount;
        });
      });

      document.querySelectorAll('.reject-btn').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var userId = this.getAttribute('data-user-id');
          if (!confirm('Reject and delete this user? This cannot be undone.')) return;
          this.disabled = true;
          this.textContent = 'Rejecting...';

          var res = await fetch('/api/admin/reject', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: userId }),
          });

          if (res.ok) {
            var card = document.querySelector('[data-user-card="' + userId + '"]');
            if (card) card.remove();
          } else {
            alert('Failed to reject user');
            this.disabled = false;
            this.textContent = 'Reject';
          }
        });
      });
    });
  </script>
</BaseLayout>

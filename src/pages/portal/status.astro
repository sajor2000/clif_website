---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import PortalNav from '../../components/portal/PortalNav.astro';
import { getDb } from '../../lib/turso';
import {
  MANUSCRIPT_STATUS_TAGS,
  STATUS_PROGRESSION,
  normalizeStatus,
  latestStatus,
  statusLabel,
  statusClasses,
} from '../../lib/manuscript-status.js';

const user = Astro.locals.user;
const isAdmin = user?.role === 'admin';
// Any approved member may add/edit manuscripts (deletion stays admin-only).
// Middleware already guarantees anyone viewing /portal/* is approved.
const canEdit = Boolean(user?.is_approved);

const db = getDb();
let manuscripts: any[] = [];
let error: string | null = null;

try {
  // Join users so we can show who last edited each row (updated_by is a user id).
  const result = await db.execute(
    `SELECT m.*, u.full_name AS updated_by_name
       FROM manuscripts m
       LEFT JOIN users u ON m.updated_by = u.id
      ORDER BY m.sort_order, m.title`
  );
  manuscripts = result.rows;
} catch (e: any) {
  error = e.message;
}

// Consortium sites for the "Contributing sites" checklist in the add/edit modal.
let siteNames: string[] = [];
try {
  const sitesRes = await db.execute('SELECT site_name FROM site_details ORDER BY site_name');
  siteNames = sitesRes.rows.map((r) => r.site_name as string);
} catch {
  /* non-fatal: fall back to an empty checklist */
}

// Canonical CLIF versions, derived from the data-dictionary content files so the
// dropdown stays in sync with the versions the site actually documents. Latest first.
const clifVersions = Object.keys(
  import.meta.glob('../../content/clif-data-dictionary-*.md')
)
  .map((p) => p.match(/clif-data-dictionary-(.+)\.md$/)?.[1])
  .filter((v): v is string => Boolean(v) && v !== '1.0.0')
  .sort((a, b) => b.localeCompare(a, undefined, { numeric: true }));

// Approved members for the "Lead authors" checklist and "Validation buddy" dropdown.
let memberNames: string[] = [];
try {
  const membersRes = await db.execute(
    "SELECT full_name FROM users WHERE is_approved = 1 AND full_name IS NOT NULL AND TRIM(full_name) != '' ORDER BY full_name"
  );
  memberNames = membersRes.rows.map((r) => r.full_name as string);
} catch {
  /* non-fatal: fall back to an empty list */
}

// Precompute the canonical status slugs for rendering chips + client editing.
const rows = manuscripts.map((m) => {
  const statusSlugs = normalizeStatus(m.status as string | null);
  // Precomputed lowercase haystack for the search box. Built server-side so it
  // isn't polluted by the inline status <select> options (which contain every
  // label) and still matches on any status tag the manuscript carries.
  const searchText = [
    m.title,
    m.lead_authors,
    m.journal,
    m.clif_version,
    m.ats,
    m.contributing_sites,
    m.validation_buddy,
    m.notes,
    ...statusSlugs.map((s: string) => statusLabel(s)),
  ]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();
  return {
    ...m,
    statusSlugs,
    latest: latestStatus(statusSlugs) as string | null,
    searchText,
  };
});

// slug -> Tailwind chip classes, handed to the client so the inline status
// dropdown can recolor itself when an admin changes a manuscript's status.
const statusClassMap: Record<string, string> = {};
for (const slug of Object.keys(MANUSCRIPT_STATUS_TAGS)) {
  statusClassMap[slug] = statusClasses(slug);
}
const STATUS_EMPTY_CLASSES = 'bg-gray-100 text-gray-600 dark:bg-neutral-700 dark:text-gray-400';

// Status tag options for the admin add/edit form (in canonical order).
const statusOptions = Object.entries(MANUSCRIPT_STATUS_TAGS).map(([slug, t]) => ({
  slug,
  label: t.label,
}));

// Minimal payload handed to the client modal for editing existing rows.
const editData = rows.map((m) => ({
  id: m.id,
  title: m.title ?? '',
  clif_version: m.clif_version ?? '',
  ats: m.ats ?? '',
  lead_authors: m.lead_authors ?? '',
  journal: m.journal ?? '',
  contributing_sites: m.contributing_sites ?? '',
  validation_buddy: m.validation_buddy ?? '',
  github_repo: m.github_repo ?? '',
  manuscript_link: m.manuscript_link ?? '',
  cite: m.cite ?? '',
  notes: m.notes ?? '',
  status: m.statusSlugs,
}));

const inputClass =
  'w-full px-3 py-2 border border-gray-300 dark:border-neutral-600 rounded-lg text-sm text-gray-900 dark:text-white bg-white dark:bg-neutral-700 focus:outline-none focus:ring-2 focus:ring-clif-burgundy focus:border-transparent';
---

<BaseLayout title="Manuscript Tracker">
  <div class="container mx-auto px-4 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <aside class="lg:w-64 shrink-0">
        <PortalNav currentPath={Astro.url.pathname} isAdmin={isAdmin} />
      </aside>

      <div class="flex-1 min-w-0">
        <div class="mb-6">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Manuscript Tracker</h1>
          <p class="text-gray-600 dark:text-gray-400 mt-1">
            Consortium manuscripts and their progress — status, leads, journals, and repositories
          </p>
        </div>

        {/* Progress map: the lifecycle a manuscript moves through. Each row shows its furthest-along stage. */}
        <div class="mb-6 bg-gradient-to-br from-white to-gray-50 dark:from-neutral-800 dark:to-neutral-800/60 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 p-5">
          <div class="flex items-baseline justify-between gap-2 mb-4">
            <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Manuscript progress</h2>
            <span class="text-xs text-gray-400 dark:text-gray-500">each row shows its furthest stage</span>
          </div>
          <ol class="grid grid-cols-4 sm:grid-cols-6 lg:grid-cols-11 gap-x-2 gap-y-4">
            {STATUS_PROGRESSION.map((slug, i) => (
              <li class="flex flex-col items-center text-center gap-1.5">
                <span class={`flex items-center justify-center w-7 h-7 rounded-full text-[11px] font-bold shadow-sm ${statusClasses(slug)}`}>
                  {i + 1}
                </span>
                <span class="text-[11px] font-semibold leading-tight text-gray-700 dark:text-gray-200">
                  {statusLabel(slug)}
                </span>
              </li>
            ))}
          </ol>
        </div>

        {/* Tabs */}
        <div class="mb-6">
          <div class="flex border-b border-gray-200 dark:border-neutral-700">
            {canEdit && (
              <button id="tab-add" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
                Add a Manuscript
              </button>
            )}
            <button id="tab-active" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-clif-burgundy text-clif-burgundy transition-colors">
              Active Manuscripts
            </button>
            <button id="tab-all" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
              All Manuscripts
            </button>
          </div>
        </div>

        {canEdit && (
          <div id="panel-add" class="tab-panel hidden">
            <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 p-6">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Add a manuscript</h2>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-1 mb-4">Add a new consortium manuscript to the tracker.</p>
              <button
                id="add-manuscript-btn"
                class="bg-clif-burgundy hover:bg-clif-burgundy/90 text-white font-medium py-2 px-4 rounded-lg text-sm transition-colors"
              >
                + Add manuscript
              </button>
            </div>
          </div>
        )}

        {error ? (
          <div class="bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-lg p-4 text-sm">
            Error loading data: {error}
          </div>
        ) : (
          <div id="panel-table" class="tab-panel">
          <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-sm border border-gray-200 dark:border-neutral-700 overflow-hidden">
            <div class="p-4 border-b border-gray-200 dark:border-neutral-700 flex flex-col sm:flex-row gap-3 sm:items-center">
              <input
                type="text"
                id="search-manuscripts"
                placeholder="Search manuscripts…"
                class="w-full md:w-72 px-4 py-2 border border-gray-300 dark:border-neutral-600 rounded-lg text-sm text-gray-900 dark:text-white bg-white dark:bg-neutral-700 focus:outline-none focus:ring-2 focus:ring-clif-burgundy focus:border-transparent"
              />
              <select
                id="filter-status"
                class="w-full sm:w-auto px-3 py-2 border border-gray-300 dark:border-neutral-600 rounded-lg text-sm text-gray-900 dark:text-white bg-white dark:bg-neutral-700 focus:outline-none focus:ring-2 focus:ring-clif-burgundy focus:border-transparent"
                aria-label="Filter by status"
              >
                <option value="">All statuses</option>
                {statusOptions.map((opt) => (
                  <option value={opt.slug}>{opt.label}</option>
                ))}
              </select>
              <span class="hidden sm:inline text-xs text-gray-400 dark:text-gray-500">· click a column header to sort</span>
            </div>

            {rows.length === 0 ? (
              <div class="p-8 text-center text-gray-500 dark:text-gray-400">No manuscripts tracked yet.</div>
            ) : (
              <div class="overflow-x-auto">
                <table class="w-full text-sm" id="manuscripts-table">
                  <thead>
                    <tr class="bg-gray-50 dark:bg-neutral-700/50 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider">
                      <th class="px-4 py-3 min-w-[18rem]" data-sort-key="title"><span class="th-label">Title</span><span class="sort-ind"></span></th>
                      <th class="px-4 py-3 whitespace-nowrap" data-sort-key="lead"><span class="th-label">Lead authors</span><span class="sort-ind"></span></th>
                      <th class="px-4 py-3" data-sort-key="status"><span class="th-label">Status</span><span class="sort-ind"></span></th>
                      <th class="px-4 py-3 whitespace-nowrap" data-sort-key="journal"><span class="th-label">Journal</span><span class="sort-ind"></span></th>
                      <th class="px-4 py-3 whitespace-nowrap" data-sort-key="ats"><span class="th-label">ATS</span><span class="sort-ind"></span></th>
                      <th class="px-4 py-3 whitespace-nowrap">Contributing sites</th>
                      <th class="px-4 py-3 whitespace-nowrap">Validation buddy</th>
                      <th class="px-4 py-3 whitespace-nowrap">GitHub</th>
                      <th class="px-4 py-3 min-w-[12rem]">Notes</th>
                      <th class="px-4 py-3 whitespace-nowrap" data-sort-key="edited"><span class="th-label">Last edited</span><span class="sort-ind"></span></th>
                      {canEdit && <th class="px-4 py-3 whitespace-nowrap">Actions</th>}
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-200 dark:divide-neutral-700">
                    {rows.map((m, i) => (
                      <tr
                        class={`align-top hover:bg-gray-50 dark:hover:bg-neutral-700/30 transition-colors ${i % 2 === 0 ? '' : 'bg-gray-50/50 dark:bg-neutral-800/50'}`}
                        data-search-row
                        data-search-text={m.searchText}
                        data-published={m.statusSlugs.includes('published') ? '1' : '0'}
                        data-status={m.statusSlugs.join(',')}
                        data-sort-title={(m.title ?? '').toLowerCase()}
                        data-sort-lead={(m.lead_authors ?? '').toLowerCase()}
                        data-sort-status={m.latest ? STATUS_PROGRESSION.indexOf(m.latest) : -1}
                        data-sort-journal={(m.journal ?? '').toLowerCase()}
                        data-sort-ats={(m.ats ?? '').toLowerCase()}
                        data-sort-edited={m.updated_at ? Date.parse(m.updated_at as string) : 0}
                      >
                        <td class="px-4 py-3 text-gray-900 dark:text-gray-200">
                          {m.manuscript_link ? (
                            <a href={m.manuscript_link} target="_blank" rel="noopener noreferrer" class="font-medium text-clif-burgundy hover:underline">
                              {m.title}
                            </a>
                          ) : (
                            <span class="font-medium">{m.title}</span>
                          )}
                          {m.clif_version && (
                            <span class="inline-flex items-center align-middle ml-1.5 px-1.5 py-0.5 rounded text-[10px] font-semibold bg-clif-burgundy/10 text-clif-burgundy dark:bg-clif-burgundy/20 whitespace-nowrap" title="CLIF version">
                              v{String(m.clif_version).replace(/\.0$/, '')}
                            </span>
                          )}
                        </td>
                        <td class="px-4 py-3 text-gray-700 dark:text-gray-300 whitespace-nowrap">{m.lead_authors ?? '—'}</td>
                        <td class="px-4 py-3">
                          {canEdit ? (
                            <select
                              class={`status-select w-40 max-w-full truncate cursor-pointer rounded-full text-xs font-medium pl-2.5 pr-7 py-1 border-0 focus:outline-none focus:ring-2 focus:ring-clif-burgundy ${m.latest ? statusClasses(m.latest) : STATUS_EMPTY_CLASSES}`}
                              data-id={m.id}
                            >
                              <option value="">—</option>
                              {m.latest && !STATUS_PROGRESSION.includes(m.latest) && (
                                <option value={m.latest} selected>{statusLabel(m.latest)}</option>
                              )}
                              {STATUS_PROGRESSION.map((slug) => (
                                <option value={slug} selected={m.latest === slug}>{statusLabel(slug)}</option>
                              ))}
                            </select>
                          ) : m.latest ? (
                            <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusClasses(m.latest)}`}>
                              {statusLabel(m.latest)}
                            </span>
                          ) : (
                            <span class="text-gray-400">—</span>
                          )}
                        </td>
                        <td class="px-4 py-3 text-gray-700 dark:text-gray-300 whitespace-nowrap">{m.journal ?? '—'}</td>
                        <td class="px-4 py-3 text-gray-700 dark:text-gray-300 whitespace-nowrap">{m.ats ?? '—'}</td>
                        <td class="px-4 py-3 text-gray-700 dark:text-gray-300">{m.contributing_sites ?? '—'}</td>
                        <td class="px-4 py-3 text-gray-700 dark:text-gray-300 whitespace-nowrap">{m.validation_buddy ?? '—'}</td>
                        <td class="px-4 py-3 whitespace-nowrap">
                          {m.github_repo ? (
                            <a href={m.github_repo} target="_blank" rel="noopener noreferrer" class="text-clif-burgundy hover:underline">Repo</a>
                          ) : (
                            <span class="text-gray-400">—</span>
                          )}
                        </td>
                        <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{m.notes ?? '—'}</td>
                        <td class="px-4 py-3 whitespace-nowrap text-xs text-gray-500 dark:text-gray-400">
                          {m.updated_at ? (
                            <Fragment>
                              {m.updated_by_name && (
                                <div class="font-medium text-gray-700 dark:text-gray-300">{m.updated_by_name}</div>
                              )}
                              <div>{new Date(m.updated_at as string).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' })}</div>
                            </Fragment>
                          ) : (
                            <span class="text-gray-400">—</span>
                          )}
                        </td>
                        {canEdit && (
                          <td class="px-4 py-3 whitespace-nowrap">
                            <div class="flex gap-3">
                              <button class="edit-manuscript-btn text-xs text-clif-burgundy hover:underline font-medium" data-id={m.id}>Edit</button>
                              {isAdmin && (
                                <button class="delete-manuscript-btn text-xs text-red-600 dark:text-red-400 hover:underline" data-id={m.id} data-title={m.title}>Delete</button>
                              )}
                            </div>
                          </td>
                        )}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}

            <div id="manuscripts-empty" class="hidden p-8 text-center text-gray-500 dark:text-gray-400 border-t border-gray-200 dark:border-neutral-700">
              No manuscripts match this view.
            </div>

            <div class="p-3 border-t border-gray-200 dark:border-neutral-700 text-xs text-gray-500 dark:text-gray-400">
              <span id="manuscripts-count">{rows.length}</span> {rows.length === 1 ? 'manuscript' : 'manuscripts'}
            </div>
          </div>
          </div>
        )}
      </div>
    </div>
  </div>

  {canEdit && (
    <dialog id="manuscript-modal" class="rounded-xl p-0 w-full max-w-2xl backdrop:bg-black/40 bg-white dark:bg-neutral-800 text-gray-900 dark:text-white">
      <form id="manuscript-form" class="p-6 space-y-4">
        <h2 id="manuscript-modal-title" class="text-lg font-semibold">Add manuscript</h2>
        <input type="hidden" id="m-id" />

        <div>
          <label for="m-title" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title <span class="text-red-500">*</span></label>
          <input type="text" id="m-title" required class={inputClass} />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="m-journal" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Journal</label>
            <input type="text" id="m-journal" class={inputClass} />
          </div>
          <div>
            <label for="m-clif_version" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">CLIF version</label>
            <select id="m-clif_version" class={inputClass}>
              <option value="">—</option>
              {clifVersions.map((v) => (
                <option value={v}>{v}</option>
              ))}
            </select>
          </div>
          <div>
            <label for="m-ats" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ATS</label>
            <input type="text" id="m-ats" class={inputClass} placeholder="e.g. ATS 2026" />
          </div>
          <div>
            <label for="m-validation_buddy" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Validation buddy</label>
            <select id="m-validation_buddy" class={inputClass}>
              <option value="">—</option>
              {memberNames.map((name) => (
                <option value={name}>{name}</option>
              ))}
            </select>
          </div>
          <div>
            <label for="m-github_repo" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">GitHub repository</label>
            <input type="url" id="m-github_repo" class={inputClass} placeholder="https://github.com/…" />
          </div>
          <div>
            <label for="m-manuscript_link" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Manuscript link</label>
            <input type="url" id="m-manuscript_link" class={inputClass} placeholder="https://…" />
          </div>
        </div>

        <div>
          <span class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Lead authors</span>
          {memberNames.length > 0 && (
            <div class="max-h-36 overflow-y-auto border border-gray-200 dark:border-neutral-600 rounded-lg p-3 flex flex-wrap gap-x-4 gap-y-2">
              {memberNames.map((name) => (
                <label class="inline-flex items-center gap-1.5 text-sm text-gray-700 dark:text-gray-300">
                  <input type="checkbox" class="m-lead-author w-4 h-4 text-clif-burgundy border-gray-300 rounded focus:ring-clif-burgundy" value={name} />
                  {name}
                </label>
              ))}
            </div>
          )}
          <input type="text" id="m-lead_authors_other" class={`${inputClass} mt-2`} placeholder="Other authors (comma-separated)" />
        </div>

        <div>
          <span class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Contributing sites</span>
          {siteNames.length > 0 && (
            <div class="max-h-36 overflow-y-auto border border-gray-200 dark:border-neutral-600 rounded-lg p-3 flex flex-wrap gap-x-4 gap-y-2">
              {siteNames.map((name) => (
                <label class="inline-flex items-center gap-1.5 text-sm text-gray-700 dark:text-gray-300">
                  <input type="checkbox" class="m-site w-4 h-4 text-clif-burgundy border-gray-300 rounded focus:ring-clif-burgundy" value={name} />
                  {name}
                </label>
              ))}
            </div>
          )}
          <input type="text" id="m-contributing_sites_other" class={`${inputClass} mt-2`} placeholder="Other sites (comma-separated)" />
        </div>

        <div>
          <span class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Status</span>
          <div class="flex flex-wrap gap-x-4 gap-y-2">
            {statusOptions.map((opt) => (
              <label class="inline-flex items-center gap-1.5 text-sm text-gray-700 dark:text-gray-300">
                <input type="checkbox" class="m-status w-4 h-4 text-clif-burgundy border-gray-300 rounded focus:ring-clif-burgundy" value={opt.slug} />
                {opt.label}
              </label>
            ))}
          </div>
        </div>

        <div>
          <label for="m-cite" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Citation</label>
          <input type="text" id="m-cite" class={inputClass} />
        </div>

        <div>
          <label for="m-notes" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Notes</label>
          <textarea id="m-notes" rows="2" class={inputClass}></textarea>
        </div>

        <div id="manuscript-error" class="hidden text-sm text-red-600 dark:text-red-400"></div>

        <div class="flex justify-end gap-3 pt-2">
          <button type="button" id="manuscript-cancel" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-neutral-700 transition-colors">Cancel</button>
          <button type="submit" id="manuscript-save" class="bg-clif-burgundy hover:bg-clif-burgundy/90 text-white font-medium py-2 px-4 rounded-lg text-sm transition-colors">Save</button>
        </div>
      </form>
    </dialog>
  )}

  <script is:inline define:vars={{ manuscripts: editData, canEdit, statusClassMap, statusEmptyClasses: STATUS_EMPTY_CLASSES }}>
    document.addEventListener('DOMContentLoaded', function () {
      // ---- Sub-tabs (Add / Active / All) + search filter ----
      var input = document.getElementById('search-manuscripts');
      var table = document.getElementById('manuscripts-table');
      var countEl = document.getElementById('manuscripts-count');
      var emptyEl = document.getElementById('manuscripts-empty');
      var tabAdd = document.getElementById('tab-add');
      var tabActive = document.getElementById('tab-active');
      var tabAll = document.getElementById('tab-all');
      var panelAdd = document.getElementById('panel-add');
      var panelTable = document.getElementById('panel-table');

      var statusSelect = document.getElementById('filter-status');

      var searchQuery = '';
      var statusFilter = ''; // '' = all statuses, else a single status slug
      var rowFilter = 'active'; // 'active' = not published, 'all' = everything

      function applyFilters() {
        if (!table) return;
        var allRows = table.querySelectorAll('[data-search-row]');
        var visible = 0;
        allRows.forEach(function (row) {
          var matchesSearch = (row.getAttribute('data-search-text') || '').includes(searchQuery);
          var matchesFilter = rowFilter === 'all' || row.getAttribute('data-published') !== '1';
          var matchesStatus = !statusFilter ||
            (row.getAttribute('data-status') || '').split(',').indexOf(statusFilter) !== -1;
          var show = matchesSearch && matchesFilter && matchesStatus;
          row.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        if (countEl) countEl.textContent = String(visible);
        if (emptyEl) emptyEl.classList.toggle('hidden', visible !== 0 || allRows.length === 0);
      }

      if (input) {
        input.addEventListener('input', function () {
          searchQuery = this.value.toLowerCase();
          applyFilters();
        });
      }

      if (statusSelect) {
        statusSelect.addEventListener('change', function () {
          statusFilter = this.value;
          applyFilters();
        });
      }

      // ---- Sortable columns (click a header to sort; click again to reverse) ----
      var currentSort = { key: null, dir: 1 };

      function updateSortIndicators() {
        if (!table) return;
        table.querySelectorAll('th[data-sort-key]').forEach(function (th) {
          var ind = th.querySelector('.sort-ind');
          if (!ind) return;
          if (th.getAttribute('data-sort-key') === currentSort.key) {
            ind.textContent = currentSort.dir === 1 ? ' ▲' : ' ▼';
          } else {
            ind.textContent = '';
          }
        });
      }

      function sortBy(key) {
        if (!table) return;
        if (currentSort.key === key) currentSort.dir *= -1;
        else { currentSort.key = key; currentSort.dir = 1; }
        var tbody = table.querySelector('tbody');
        if (!tbody) return;
        var attr = 'data-sort-' + key;
        var rows = Array.prototype.slice.call(tbody.querySelectorAll('[data-search-row]'));
        rows.sort(function (a, b) {
          var av = a.getAttribute(attr) || '';
          var bv = b.getAttribute(attr) || '';
          var an = parseFloat(av), bn = parseFloat(bv);
          var cmp;
          if (av !== '' && bv !== '' && !isNaN(an) && !isNaN(bn) && String(an) === av && String(bn) === bv) {
            cmp = an - bn; // numeric columns (status stage, last-edited timestamp)
          } else {
            cmp = av.localeCompare(bv);
          }
          return cmp * currentSort.dir;
        });
        rows.forEach(function (r) { tbody.appendChild(r); });
        updateSortIndicators();
        applyFilters();
      }

      if (table) {
        table.querySelectorAll('th[data-sort-key]').forEach(function (th) {
          th.classList.add('cursor-pointer', 'select-none');
          th.title = 'Click to sort';
          th.addEventListener('click', function () {
            sortBy(th.getAttribute('data-sort-key'));
          });
        });
      }

      function setActiveTab(btn) {
        [tabAdd, tabActive, tabAll].forEach(function (b) {
          if (!b) return;
          b.classList.remove('border-clif-burgundy', 'text-clif-burgundy');
          b.classList.add('border-transparent', 'text-gray-500', 'dark:text-gray-400');
        });
        btn.classList.add('border-clif-burgundy', 'text-clif-burgundy');
        btn.classList.remove('border-transparent', 'text-gray-500', 'dark:text-gray-400');
      }

      function showTable(filter, btn) {
        setActiveTab(btn);
        if (panelAdd) panelAdd.classList.add('hidden');
        if (panelTable) panelTable.classList.remove('hidden');
        rowFilter = filter;
        applyFilters();
      }

      if (tabAdd) tabAdd.addEventListener('click', function () {
        setActiveTab(tabAdd);
        if (panelTable) panelTable.classList.add('hidden');
        if (panelAdd) panelAdd.classList.remove('hidden');
      });
      if (tabActive) tabActive.addEventListener('click', function () { showTable('active', tabActive); });
      if (tabAll) tabAll.addEventListener('click', function () { showTable('all', tabAll); });

      // Default view: Active Manuscripts
      applyFilters();

      if (!canEdit) return;

      // ---- Inline status dropdown (quick-edit without opening the modal) ----
      var STATUS_SELECT_BASE = 'status-select w-40 max-w-full truncate cursor-pointer rounded-full text-xs font-medium pl-2.5 pr-7 py-1 border-0 focus:outline-none focus:ring-2 focus:ring-clif-burgundy';
      document.querySelectorAll('.status-select').forEach(function (sel) {
        var prev = sel.value;
        sel.addEventListener('change', async function () {
          var id = this.dataset.id;
          var slug = this.value;
          this.disabled = true;
          var res = await fetch('/api/manuscripts/update-status', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: id, status: slug ? [slug] : [] }),
          });
          if (res.ok) {
            // Recolor the dropdown and keep Active/All filtering in sync.
            this.className = STATUS_SELECT_BASE + ' ' + (slug ? (statusClassMap[slug] || statusEmptyClasses) : statusEmptyClasses);
            var row = this.closest('[data-search-row]');
            if (row) row.setAttribute('data-published', slug === 'published' ? '1' : '0');
            prev = slug;
            applyFilters();
            this.disabled = false;
          } else {
            var data = await res.json().catch(function () { return {}; });
            alert(data.error || 'Failed to update status');
            this.value = prev; // revert
            this.disabled = false;
          }
        });
      });

      // ---- Add / edit modal ----
      var modal = document.getElementById('manuscript-modal');
      var form = document.getElementById('manuscript-form');
      var modalTitle = document.getElementById('manuscript-modal-title');
      var errorEl = document.getElementById('manuscript-error');
      var saveBtn = document.getElementById('manuscript-save');
      var byId = {};
      manuscripts.forEach(function (m) { byId[m.id] = m; });

      // lead_authors, contributing_sites, validation_buddy and clif_version are
      // handled separately as checkbox lists / dropdowns.
      var TEXT_FIELDS = ['title', 'journal', 'ats',
        'github_repo', 'manuscript_link', 'cite', 'notes'];

      function setField(name, value) {
        var el = document.getElementById('m-' + name);
        if (el) el.value = value || '';
      }

      // Check the boxes (class `cls`) whose value matches a name in the stored
      // comma-separated string; anything unmatched goes into the `otherId` input
      // so existing free-text values are preserved.
      function setChecklist(cls, otherId, raw) {
        var boxes = form.querySelectorAll('.' + cls);
        var known = {};
        boxes.forEach(function (cb) { cb.checked = false; known[cb.value.toLowerCase()] = cb; });
        var leftover = [];
        String(raw || '').split(',').forEach(function (part) {
          var name = part.trim();
          if (!name) return;
          var cb = known[name.toLowerCase()];
          if (cb) cb.checked = true;
          else leftover.push(name);
        });
        var otherEl = document.getElementById(otherId);
        if (otherEl) otherEl.value = leftover.join(', ');
      }

      // Read a checklist + its "other" input back into one comma-separated string.
      function readChecklist(cls, otherId) {
        var vals = [];
        form.querySelectorAll('.' + cls + ':checked').forEach(function (cb) { vals.push(cb.value); });
        var otherEl = document.getElementById(otherId);
        if (otherEl && otherEl.value.trim()) {
          otherEl.value.split(',').forEach(function (p) { if (p.trim()) vals.push(p.trim()); });
        }
        return vals.join(', ');
      }

      // Set a <select> to `value`, adding a matching option first if the stored
      // value isn't already in the list so existing data is preserved.
      function setSelectValue(id, value) {
        var sel = document.getElementById(id);
        if (!sel) return;
        var v = value || '';
        if (v && !Array.prototype.some.call(sel.options, function (o) { return o.value === v; })) {
          var opt = document.createElement('option');
          opt.value = v;
          opt.textContent = v;
          sel.appendChild(opt);
        }
        sel.value = v;
      }

      function openModal(data) {
        errorEl.classList.add('hidden');
        document.getElementById('m-id').value = data ? data.id : '';
        TEXT_FIELDS.forEach(function (f) { setField(f, data ? data[f] : ''); });
        setChecklist('m-lead-author', 'm-lead_authors_other', data ? data.lead_authors : '');
        setChecklist('m-site', 'm-contributing_sites_other', data ? data.contributing_sites : '');
        setSelectValue('m-validation_buddy', data ? data.validation_buddy : '');
        setSelectValue('m-clif_version', data ? data.clif_version : '');
        var selected = data && data.status ? data.status : [];
        form.querySelectorAll('.m-status').forEach(function (cb) {
          cb.checked = selected.indexOf(cb.value) !== -1;
        });
        modalTitle.textContent = data ? 'Edit manuscript' : 'Add manuscript';
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save';
        modal.showModal();
      }

      var addBtn = document.getElementById('add-manuscript-btn');
      if (addBtn) addBtn.addEventListener('click', function () { openModal(null); });

      document.querySelectorAll('.edit-manuscript-btn').forEach(function (btn) {
        btn.addEventListener('click', function () { openModal(byId[this.dataset.id]); });
      });

      var cancelBtn = document.getElementById('manuscript-cancel');
      if (cancelBtn) cancelBtn.addEventListener('click', function () { modal.close(); });

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        errorEl.classList.add('hidden');
        saveBtn.disabled = true;
        saveBtn.textContent = 'Saving…';

        var id = document.getElementById('m-id').value;
        var payload = { status: [] };
        TEXT_FIELDS.forEach(function (f) {
          payload[f] = document.getElementById('m-' + f).value;
        });
        payload.lead_authors = readChecklist('m-lead-author', 'm-lead_authors_other');
        payload.contributing_sites = readChecklist('m-site', 'm-contributing_sites_other');
        var buddyEl = document.getElementById('m-validation_buddy');
        payload.validation_buddy = buddyEl ? buddyEl.value : '';
        var clifEl = document.getElementById('m-clif_version');
        payload.clif_version = clifEl ? clifEl.value : '';
        form.querySelectorAll('.m-status:checked').forEach(function (cb) {
          payload.status.push(cb.value);
        });
        var endpoint = '/api/manuscripts/create';
        if (id) { payload.id = id; endpoint = '/api/manuscripts/update'; }

        var res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          window.location.reload();
        } else {
          var data = await res.json().catch(function () { return {}; });
          errorEl.textContent = data.error || 'Failed to save manuscript';
          errorEl.classList.remove('hidden');
          saveBtn.disabled = false;
          saveBtn.textContent = 'Save';
        }
      });

      // ---- Delete ----
      document.querySelectorAll('.delete-manuscript-btn').forEach(function (btn) {
        btn.addEventListener('click', async function () {
          if (!confirm('Delete "' + this.dataset.title + '"? This cannot be undone.')) return;
          var res = await fetch('/api/manuscripts/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: this.dataset.id }),
          });
          if (res.ok) window.location.reload();
          else alert('Failed to delete manuscript.');
        });
      });
    });
  </script>
</BaseLayout>

---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimatedHero from '../components/home/AnimatedHero.astro';
import CTAButton from '../components/shared/CTAButton.astro';
---

<BaseLayout
  title="CLIF Consortium"
  description="The Common Longitudinal ICU data Format (CLIF) - A standardized framework for organizing critical care EHR data across multiple institutions, enabling federated multicenter research."
>
  <!-- Animated Hero Section -->
  <AnimatedHero />

  <div class="container mx-auto px-4 py-12">

    <!-- Quick Links Section -->
    <section class="mb-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/research" class="group bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md hover:border-clif-burgundy/20 transition-all">
          <div class="text-clif-burgundy mb-3">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1 group-hover:text-clif-burgundy transition-colors">Publications</h3>
          <p class="text-sm text-gray-500">Research in top-tier journals</p>
        </a>

        <a href="/data-dictionary/data-dictionary-2.1.0" class="group bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md hover:border-clif-burgundy/20 transition-all">
          <div class="text-clif-burgundy mb-3">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1 group-hover:text-clif-burgundy transition-colors">Data Dictionary</h3>
          <p class="text-sm text-gray-500">CLIF 2.1.0</p>
        </a>

        <a href="/cohort" class="group bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md hover:border-clif-burgundy/20 transition-all">
          <div class="text-clif-burgundy mb-3">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1 group-hover:text-clif-burgundy transition-colors">Cohort Dashboard</h3>
          <p class="text-sm text-gray-500">Explore consortium data</p>
        </a>

        <a href="/tools" class="group bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md hover:border-clif-burgundy/20 transition-all">
          <div class="text-clif-burgundy mb-3">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1 group-hover:text-clif-burgundy transition-colors">Open Source Tools</h3>
          <p class="text-sm text-gray-500">ETL pipelines and more</p>
        </a>
      </div>
    </section>

    <!-- News Flash: MIMIC-IV-Ext-CLIF -->
    <section class="mb-16">
      <div class="max-w-5xl mx-auto relative overflow-hidden bg-gradient-to-r from-clif-burgundy to-clif-burgundy-dark rounded-xl shadow-lg p-6 md:p-8">
        <!-- Decorative background pattern -->
        <div class="absolute inset-0 opacity-10">
          <div class="absolute -right-8 -top-8 w-40 h-40 border-2 border-white rounded-full"></div>
          <div class="absolute -right-4 -top-4 w-28 h-28 border-2 border-white rounded-full"></div>
        </div>
        <div class="relative flex flex-col lg:flex-row gap-6 lg:gap-8 items-center">
          <!-- Text content -->
          <div class="flex-1">
            <h3 class="text-2xl md:text-3xl font-bold text-white mb-3 flex items-center gap-3">
              <span class="relative flex h-3 w-3 shrink-0">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-300 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3 w-3 bg-yellow-400"></span>
              </span>
              MIMIC-IV in CLIF Format — Now on PhysioNet
            </h3>
            <p class="text-white/80 leading-relaxed mb-5">
              MIMIC-IV is now available in CLIF format on PhysioNet — enabling researchers worldwide to develop and test analysis code using the CLIF standard without requiring institutional EHR access.
            </p>
            <p class="text-sm text-white/50 mb-5">Zewei Liao et al.</p>
            <CTAButton href="https://physionet.org/content/mimic-iv-ext-clif/1.1.0/" variant="outline" size="medium" external={true} class="!border-white !text-white hover:!bg-white hover:!text-clif-burgundy">
              Access on PhysioNet
            </CTAButton>
          </div>
          <!-- PhysioNet preview -->
          <div class="hidden lg:block lg:w-80 shrink-0">
            <img
              src="/images/misc/physionet_mimic_clif.png"
              alt="MIMIC-IV-Ext-CLIF on PhysioNet"
              class="rounded-lg shadow-xl border border-white/20 w-full"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Why CLIF -->
    <section class="mb-16 max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row gap-8 items-start">
        <div class="md:w-1/2">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Built for Critical Care Research</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            We've built a geographically diverse network of clinician-scientists, data scientists, and leading academic medical centers across North America. Together, we leverage deep expertise in EHR-based clinical outcomes research and AI applications to advance critical care through collaborative, data-driven research.
          </p>
          <a href="/about" class="text-clif-burgundy font-medium text-sm inline-flex items-center gap-1 hover:underline">
            Read more about CLIF
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
        <div class="md:w-1/2 space-y-4">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-clif-burgundy/10 text-clif-burgundy flex items-center justify-center mt-0.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-sm">Standardized Format</p>
              <p class="text-sm text-gray-500">Purpose-built for longitudinal ICU data, eliminating months of ad-hoc harmonization.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-clif-burgundy/10 text-clif-burgundy flex items-center justify-center mt-0.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-sm">Privacy-Preserving</p>
              <p class="text-sm text-gray-500">Federated analytics — only aggregate results are shared, no patient data leaves the institution.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-clif-burgundy/10 text-clif-burgundy flex items-center justify-center mt-0.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-sm">Rapid Multicenter Research</p>
              <p class="text-sm text-gray-500">Write once, run across 12+ sites. Hypothesis to multicenter results in weeks, not years.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-clif-burgundy/10 text-clif-burgundy flex items-center justify-center mt-0.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-sm">Open Source</p>
              <p class="text-sm text-gray-500">Apache License 2.0 — all tools, ETL pipelines, and specifications are openly available on <a href="https://github.com/clif-consortium" target="_blank" rel="noopener noreferrer" class="text-clif-burgundy hover:underline">GitHub</a>.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Consortium Map -->
    <section class="mb-16">
      <div class="max-w-5xl mx-auto">
        <div class="bg-white dark:!bg-transparent rounded-xl shadow-sm border border-gray-100 p-4">
          <img
            src="/images/misc/clif_map.png"
            alt="Map of CLIF Consortium Sites"
            class="w-full rounded-lg dark:hidden"
            loading="lazy"
            decoding="async"
          />
          <img
            src="/images/misc/clif_map_dark.png"
            alt="Map of CLIF Consortium Sites"
            class="w-full rounded-lg hidden dark:block"
            loading="lazy"
            decoding="async"
          />
        </div>
        <p class="text-center text-sm text-gray-500 mt-4">
          17 institutions · 62 hospitals · 12 active sites
        </p>
      </div>
    </section>


  </div>
</BaseLayout>

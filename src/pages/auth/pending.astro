---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { createAdminClient } from '../../lib/supabase';

const user = Astro.locals.user;

// If logged in, check approval status using admin client (bypasses RLS)
if (user) {
  const adminClient = createAdminClient();
  const { data: profile } = await adminClient
    .from('profiles')
    .select('is_approved')
    .eq('id', user.id)
    .single();

  if (profile?.is_approved) {
    return Astro.redirect('/portal');
  }
}
---

<BaseLayout title="Pending Approval">
  <div class="min-h-[60vh] flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-lg text-center">
      <div class="bg-white dark:bg-neutral-800 rounded-2xl shadow-lg p-8">
        <div class="mx-auto w-16 h-16 bg-yellow-100 dark:bg-yellow-900/30 rounded-full flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-yellow-600 dark:text-yellow-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>

        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">Account Pending Approval</h1>

        {user ? (
          <div class="space-y-4">
            <p class="text-gray-600 dark:text-gray-400">
              Your account (<span class="font-medium">{user.email}</span>) has been created successfully.
            </p>
            <p class="text-gray-600 dark:text-gray-400">
              A CLIF Consortium administrator will review your request and grant access to the Members Portal. You'll be able to sign in once approved.
            </p>
          </div>
        ) : (
          <p class="text-gray-600 dark:text-gray-400">
            Your account is pending administrator approval. Please check back later.
          </p>
        )}

        <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/"
            class="inline-flex items-center justify-center px-6 py-2.5 border border-gray-300 dark:border-neutral-600 rounded-lg text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-neutral-700 transition-colors text-sm font-medium"
          >
            Back to Home
          </a>
          {user && (
            <button
              id="logout-btn"
              class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium text-red-600 dark:text-red-400 border border-red-300 dark:border-red-800 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
            >
              Sign Out
            </button>
          )}
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    var logoutBtn = document.getElementById('logout-btn');
    if (logoutBtn) {
      logoutBtn.addEventListener('click', async function() {
        await fetch('/api/auth/logout', { method: 'POST' });
        window.location.href = '/';
      });
    }
  </script>
</BaseLayout>

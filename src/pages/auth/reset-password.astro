---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Reset Password">
  <div class="min-h-[60vh] flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">
      <div class="bg-white dark:bg-neutral-800 rounded-2xl shadow-lg p-8">
        <div class="text-center mb-8">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Reset Password</h1>
          <p class="text-gray-600 dark:text-gray-400 mt-2">Answer your security question to reset your password</p>
        </div>

        <!-- Step 1: Enter email -->
        <form id="email-form" class="space-y-5">
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email</label>
            <input
              type="email"
              id="email"
              required
              class="w-full px-4 py-2.5 border border-gray-300 dark:border-neutral-600 rounded-lg text-gray-900 dark:text-white bg-white dark:bg-neutral-700 focus:outline-none focus:ring-2 focus:ring-clif-burgundy focus:border-transparent"
              placeholder="you@institution.edu"
            />
          </div>
          <div id="email-error" class="hidden text-sm text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 rounded-lg px-4 py-3"></div>
          <button
            type="submit"
            id="email-btn"
            class="w-full bg-clif-burgundy hover:bg-clif-burgundy/90 text-white font-medium py-2.5 px-4 rounded-lg transition-colors"
          >
            Continue
          </button>
        </form>

        <!-- Step 2: Answer question + new password (hidden initially) -->
        <form id="reset-form" class="space-y-5 hidden">
          <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg px-4 py-3">
            <p class="text-sm font-medium text-blue-800 dark:text-blue-300" id="question-text"></p>
          </div>
          <div>
            <label for="security_answer" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Your Answer</label>
            <input
              type="text"
              id="security_answer"
              required
              class="w-full px-4 py-2.5 border border-gray-300 dark:border-neutral-600 rounded-lg text-gray-900 dark:text-white bg-white dark:bg-neutral-700 focus:outline-none focus:ring-2 focus:ring-clif-burgundy focus:border-transparent"
              placeholder="Case-insensitive"
            />
          </div>
          <div>
            <label for="new_password" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">New Password</label>
            <input
              type="password"
              id="new_password"
              required
              minlength="6"
              class="w-full px-4 py-2.5 border border-gray-300 dark:border-neutral-600 rounded-lg text-gray-900 dark:text-white bg-white dark:bg-neutral-700 focus:outline-none focus:ring-2 focus:ring-clif-burgundy focus:border-transparent"
              placeholder="At least 6 characters"
            />
          </div>
          <div id="reset-error" class="hidden text-sm text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 rounded-lg px-4 py-3"></div>
          <button
            type="submit"
            id="reset-btn"
            class="w-full bg-clif-burgundy hover:bg-clif-burgundy/90 text-white font-medium py-2.5 px-4 rounded-lg transition-colors"
          >
            Reset Password
          </button>
        </form>

        <!-- Success message (hidden initially) -->
        <div id="success-message" class="hidden text-center space-y-4">
          <div class="mx-auto w-16 h-16 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-green-600 dark:text-green-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <p class="text-gray-600 dark:text-gray-400">Your password has been reset. You can now sign in with your new password.</p>
          <a href="/auth/login" class="inline-block bg-clif-burgundy hover:bg-clif-burgundy/90 text-white font-medium py-2.5 px-6 rounded-lg transition-colors">
            Sign In
          </a>
        </div>

        <p class="text-center text-sm text-gray-600 dark:text-gray-400 mt-6">
          <a href="/auth/login" class="text-clif-burgundy hover:text-clif-burgundy/80 font-medium">Back to Sign In</a>
        </p>
      </div>
    </div>
  </div>

  <script is:inline>
    var userEmail = '';

    // Step 1: Get security question
    document.getElementById('email-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      var errorEl = document.getElementById('email-error');
      var btn = document.getElementById('email-btn');
      errorEl.classList.add('hidden');
      btn.disabled = true;
      btn.textContent = 'Looking up account...';

      try {
        userEmail = document.getElementById('email').value;
        var res = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: userEmail, step: 'get_question' }),
        });

        var data = await res.json();
        if (res.ok) {
          document.getElementById('question-text').textContent = data.security_question;
          document.getElementById('email-form').classList.add('hidden');
          document.getElementById('reset-form').classList.remove('hidden');
        } else {
          errorEl.textContent = data.error || 'Account not found.';
          errorEl.classList.remove('hidden');
        }
      } catch (err) {
        errorEl.textContent = 'Network error. Please try again.';
        errorEl.classList.remove('hidden');
      }

      btn.disabled = false;
      btn.textContent = 'Continue';
    });

    // Step 2: Verify answer and reset
    document.getElementById('reset-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      var errorEl = document.getElementById('reset-error');
      var btn = document.getElementById('reset-btn');
      errorEl.classList.add('hidden');
      btn.disabled = true;
      btn.textContent = 'Resetting...';

      try {
        var res = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: userEmail,
            step: 'reset',
            security_answer: document.getElementById('security_answer').value,
            new_password: document.getElementById('new_password').value,
          }),
        });

        var data = await res.json();
        if (res.ok) {
          document.getElementById('reset-form').classList.add('hidden');
          document.getElementById('success-message').classList.remove('hidden');
        } else {
          errorEl.textContent = data.error || 'Reset failed.';
          errorEl.classList.remove('hidden');
        }
      } catch (err) {
        errorEl.textContent = 'Network error. Please try again.';
        errorEl.classList.remove('hidden');
      }

      btn.disabled = false;
      btn.textContent = 'Reset Password';
    });
  </script>
</BaseLayout>

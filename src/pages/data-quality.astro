---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/shared/CTAButton.astro';
---

<BaseLayout
  title="CLIF Consortium - Data Quality Assurance"
  description="Learn about CLIF's three-pillar data quality assurance framework: Conformance, Completeness, and Plausibility checks that ensure reliable critical care research data."
>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-emerald-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-violet-500 rounded-full blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-blue-500 rounded-full blur-3xl"></div>
    </div>
    <div class="relative container mx-auto px-4 py-20 md:py-28 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 text-sm font-medium mb-6">
        <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Quality Framework
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">Data Quality Assurance</h1>
      <p class="text-lg md:text-xl text-gray-300 max-w-3xl mx-auto mb-10">
        The CLIF Consortium validates every dataset through a rigorous three-pillar framework — <span class="text-emerald-400 font-semibold">Conformance</span>, <span class="text-blue-400 font-semibold">Completeness</span>, and <span class="text-violet-400 font-semibold">Plausibility</span> — catching data issues before they reach your analysis.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <div class="bg-white/10 backdrop-blur-sm rounded-full px-5 py-2.5 text-sm font-medium border border-emerald-400/30">
          <span class="text-emerald-400 font-bold">7</span> Conformance Checks
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-full px-5 py-2.5 text-sm font-medium border border-blue-400/30">
          <span class="text-blue-400 font-bold">3</span> Completeness Checks
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-full px-5 py-2.5 text-sm font-medium border border-violet-400/30">
          <span class="text-violet-400 font-bold">7</span> Plausibility Checks
        </div>
      </div>
    </div>
  </section>

  <!-- Pillar Overview Cards (overlapping hero) -->
  <section class="container mx-auto px-4 -mt-12 relative z-10 mb-20">
    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      <!-- Conformance Card -->
      <button type="button" data-pillar-card="conformance" class="group bg-white dark:bg-neutral-800 rounded-2xl shadow-xl p-6 border-t-4 border-emerald-500 hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 text-left">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-12 h-12 bg-emerald-100 dark:bg-emerald-900/30 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">Step 1</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-1">Conformance</h3>
        <p class="text-xs font-semibold text-emerald-600 dark:text-emerald-400 mb-2">Schema & Structure</p>
        <p class="text-gray-600 dark:text-gray-300 text-sm mb-3">Does the data have the right <strong>structure</strong>? Validates tables, columns, data types, and allowed values against the CLIF schema.</p>
        <span class="text-emerald-600 dark:text-emerald-400 text-sm font-semibold group-hover:underline">7 checks &rarr;</span>
      </button>

      <!-- Completeness Card -->
      <button type="button" data-pillar-card="completeness" class="group bg-white dark:bg-neutral-800 rounded-2xl shadow-xl p-6 border-t-4 border-blue-500 hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 text-left">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7"/>
            </svg>
          </div>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">Step 2</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-1">Completeness</h3>
        <p class="text-xs font-semibold text-blue-600 dark:text-blue-400 mb-2">Data Coverage</p>
        <p class="text-gray-600 dark:text-gray-300 text-sm mb-3">Is the data <strong>filled in</strong>? Flags missing values, empty fields, and gaps in expected coverage.</p>
        <span class="text-blue-600 dark:text-blue-400 text-sm font-semibold group-hover:underline">3 checks &rarr;</span>
      </button>

      <!-- Plausibility Card -->
      <button type="button" data-pillar-card="plausibility" class="group bg-white dark:bg-neutral-800 rounded-2xl shadow-xl p-6 border-t-4 border-violet-500 hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 text-left">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-12 h-12 bg-violet-100 dark:bg-violet-900/30 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-violet-600 dark:text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
          </div>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-violet-100 text-violet-700 dark:bg-violet-900/30 dark:text-violet-400">Step 3</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-1">Plausibility</h3>
        <p class="text-xs font-semibold text-violet-600 dark:text-violet-400 mb-2">Clinical Sense</p>
        <p class="text-gray-600 dark:text-gray-300 text-sm mb-3">Does the data <strong>make sense</strong>? Catches clinically impossible values and temporal contradictions.</p>
        <span class="text-violet-600 dark:text-violet-400 text-sm font-semibold group-hover:underline">7 checks &rarr;</span>
      </button>
    </div>
  </section>

  <!-- Sticky Tab Navigation -->
  <nav class="sticky top-16 z-30 bg-white/80 dark:bg-neutral-900/80 backdrop-blur-md border-b border-gray-200 dark:border-neutral-700" id="pillar-nav" role="tablist" aria-label="Quality pillars">
    <div class="container mx-auto px-4">
      <div class="flex justify-center gap-2 md:gap-8 py-3">
        <button role="tab" aria-selected="true" aria-controls="panel-conformance" data-pillar="conformance" class="pillar-tab text-sm font-semibold transition-colors flex items-center gap-2 px-3 py-1.5 rounded-lg text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/20">
          <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
          <span class="hidden sm:inline">Conformance</span>
          <span class="sm:hidden">1</span>
        </button>
        <button role="tab" aria-selected="false" aria-controls="panel-completeness" data-pillar="completeness" class="pillar-tab text-sm font-semibold transition-colors flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400">
          <span class="w-2 h-2 rounded-full bg-blue-500"></span>
          <span class="hidden sm:inline">Completeness</span>
          <span class="sm:hidden">2</span>
        </button>
        <button role="tab" aria-selected="false" aria-controls="panel-plausibility" data-pillar="plausibility" class="pillar-tab text-sm font-semibold transition-colors flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-500 dark:text-gray-400 hover:text-violet-600 dark:hover:text-violet-400">
          <span class="w-2 h-2 rounded-full bg-violet-500"></span>
          <span class="hidden sm:inline">Plausibility</span>
          <span class="sm:hidden">3</span>
        </button>
      </div>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════ -->
  <!-- CONFORMANCE DEEP DIVE                      -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="panel-conformance" role="tabpanel" data-pillar="conformance" class="tabpanel tabpanel-active py-16 bg-gradient-to-b from-white to-emerald-50/30 dark:from-neutral-900 dark:to-emerald-950/10">
    <div class="container mx-auto px-4 max-w-5xl">
      <!-- Section Header -->
      <div class="flex items-center gap-4 mb-4">
        <div class="w-12 h-12 bg-emerald-100 dark:bg-emerald-900/30 rounded-xl flex items-center justify-center">
          <svg class="w-6 h-6 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Conformance</h2>
          <p class="text-emerald-600 dark:text-emerald-400 font-semibold text-sm">Schema & Structure</p>
        </div>
      </div>
      <p class="text-gray-700 dark:text-gray-300 mb-10 max-w-3xl">
        Conformance checks verify <strong>structure and schema</strong> — do the right tables exist, are the required columns present, are data types valid, and do categorical values belong to the allowed vocabulary? These are the first line of defense: if the skeleton is wrong, nothing downstream matters.
      </p>

      <div class="space-y-4">
        <!-- A.1 Table Presence -->
        <div class="check-card bg-white dark:bg-neutral-800 rounded-2xl shadow-md border border-gray-100 dark:border-neutral-700 overflow-hidden">
          <button type="button" class="check-trigger w-full p-6 flex items-start justify-between gap-3" aria-expanded="false">
            <div class="flex items-center gap-3">
              <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 mt-1 flex-shrink-0"></span>
              <div class="text-left">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white">A.1 Table Presence</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">Checks that all required CLIF tables exist and contain at least one row of data.</p>
              </div>
            </div>
            <div class="flex items-center gap-3 flex-shrink-0">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400">ERROR</span>
              <svg class="check-chevron w-5 h-5 text-gray-400 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>
          </button>
          <div class="check-content">
            <div class="px-6 pb-6">
              <div class="grid md:grid-cols-2 gap-4">
                <div class="rounded-xl border-2 border-emerald-200 dark:border-emerald-800 bg-emerald-50/50 dark:bg-emerald-950/20 p-4">
                  <div class="flex items-center gap-2 mb-3">
                    <svg class="w-4 h-4 text-emerald-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    <span class="text-sm font-semibold text-emerald-700 dark:text-emerald-400">PASS</span>
                  </div>
                  <div class="font-mono text-xs space-y-1 text-gray-700 dark:text-gray-300">
                    <div class="flex justify-between"><span>patient.parquet</span><span class="text-emerald-600">12,847 rows</span></div>
                    <div class="flex justify-between"><span>hospitalization.parquet</span><span class="text-emerald-600">15,203 rows</span></div>
                    <div class="flex justify-between"><span>vitals.parquet</span><span class="text-emerald-600">1,204,881 rows</span></div>
                    <div class="flex justify-between"><span>labs.parquet</span><span class="text-emerald-600">892,456 rows</span></div>
                  </div>
                </div>
                <div class="rounded-xl border-2 border-red-200 dark:border-red-800 bg-red-50/50 dark:bg-red-950/20 p-4">
                  <div class="flex items-center gap-2 mb-3">
                    <svg class="w-4 h-4 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                    <span class="text-sm font-semibold text-red-700 dark:text-red-400">FAIL</span>
                  </div>
                  <div class="font-mono text-xs space-y-1 text-gray-700 dark:text-gray-300">
                    <div class="flex justify-between"><span>patient.parquet</span><span class="text-emerald-600">12,847 rows</span></div>
                    <div class="flex justify-between"><span>hospitalization.parquet</span><span class="text-emerald-600">15,203 rows</span></div>
                    <div class="flex justify-between"><span class="text-red-600 dark:text-red-400 font-semibold">vitals.parquet</span><span class="text-red-600 dark:text-red-400 font-semibold">MISSING</span></div>
                    <div class="flex justify-between"><span>labs.parquet</span><span class="text-emerald-600">892,456 rows</span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- A.2 Required Columns -->
        <div class="check-card bg-white dark:bg-neutral-800 rounded-2xl shadow-md border border-gray-100 dark:border-neutral-700 overflow-hidden">
          <button type="button" class="check-trigger w-full p-6 flex items-start justify-between gap-3" aria-expanded="false">
            <div class="flex items-center gap-3">
              <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 mt-1 flex-shrink-0"></span>
              <div class="text-left">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white">A.2 Required Columns</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">Checks that all schema-defined columns are present in each data file.</p>
              </div>
            </div>
            <div class="flex items-center gap-3 flex-shrink-0">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400">ERROR</span>
              <svg class="check-chevron w-5 h-5 text-gray-400 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>
          </button>
          <div class="check-content">
            <div class="px-6 pb-6">
              <div class="grid md:grid-cols-2 gap-4">
                <div class="rounded-xl border-2 border-emerald-200 dark:border-emerald-800 bg-emerald-50/50 dark:bg-emerald-950/20 p-4">
                  <div class="flex items-center gap-2 mb-3">
                    <svg class="w-4 h-4 text-emerald-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    <span class="text-sm font-semibold text-emerald-700 dark:text-emerald-400">PASS — hospitalization</span>
                  </div>
                  <div class="font-mono text-xs space-y-1 text-gray-700 dark:text-gray-300">
                    <div>hospitalization_id <span class="text-emerald-600">&check;</span></div>
                    <div>patient_id <span class="text-emerald-600">&check;</span></div>
                    <div>admission_dttm <span class="text-emerald-600">&check;</span></div>
                    <div>discharge_dttm <span class="text-emerald-600">&check;</span></div>
                    <div>hospital_id <span class="text-emerald-600">&check;</span></div>
                  </div>
                </div>
                <div class="rounded-xl border-2 border-red-200 dark:border-red-800 bg-red-50/50 dark:bg-red-950/20 p-4">
                  <div class="flex items-center gap-2 mb-3">
                    <svg class="w-4 h-4 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                    <span class="text-sm font-semibold text-red-700 dark:text-red-400">FAIL — hospitalization</span>
                  </div>
                  <div class="font-mono text-xs space-y-1 text-gray-700 dark:text-gray-300">
                    <div>hospitalization_id <span class="text-emerald-600">&check;</span></div>
                    <div>patient_id <span class="text-emerald-600">&check;</span></div>
                    <div>admission_dttm <span class="text-emerald-600">&check;</span></div>
                    <div class="text-red-600 dark:text-red-400 font-semibold">discharge_dttm &cross; missing</div>
                    <div>hospital_id <span class="text-emerald-600">&check;</span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- B.1 Data Types -->
        <div class="check-card bg-white dark:bg-neutral-800 rounded-2xl shadow-md border border-gray-100 dark:border-neutral-700 overflow-hidden">
          <button type="button" class="check-trigger w-full p-6 flex items-start justify-between gap-3" aria-expanded="false">
            <div class="flex items-center gap-3">
              <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 mt-1 flex-shrink-0"></span>
              <div class="text-left">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white">B.1 Data Types</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">Validates that each column uses the expected data type (numeric, string, datetime, etc.).</p>
              </div>
            </div>
            <div class="flex items-center gap-3 flex-shrink-0">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400">ERROR</span>
              <svg class="check-chevron w-5 h-5 text-gray-400 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>
          </button>
          <div class="check-content">
            <div class="px-6 pb-6">
              <div class="grid md:grid-cols-2 gap-4">
                <div class="rounded-xl border-2 border-emerald-200 dark:border-emerald-800 bg-emerald-50/50 dark:bg-emerald-950/20 p-4">
                  <div class="flex items-center gap-2 mb-3">
                    <svg class="w-4 h-4 text-emerald-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    <span class="text-sm font-semibold text-emerald-700 dark:text-emerald-400">PASS</span>
                  </div>
                  <table class="w-full font-mono text-xs">
                    <thead><tr class="text-gray-500 dark:text-gray-400"><th class="text-left pb-1">Column</th><th class="text-left pb-1">Type</th></tr></thead>
                    <tbody class="text-gray-700 dark:text-gray-300">
                      <tr><td>weight</td><td class="text-emerald-600">float64</td></tr>
                      <tr><td>height</td><td class="text-emerald-600">float64</td></tr>
                      <tr><td>age</td><td class="text-emerald-600">int64</td></tr>
                    </tbody>
                  </table>
                </div>
                <div class="rounded-xl border-2 border-red-200 dark:border-red-800 bg-red-50/50 dark:bg-red-950/20 p-4">
                  <div class="flex items-center gap-2 mb-3">
                    <svg class="w-4 h-4 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                    <span class="text-sm font-semibold text-red-700 dark:text-red-400">FAIL</span>
                  </div>
                  <table class="w-full font-mono text-xs">
                    <thead><tr class="text-gray-500 dark:text-gray-400"><th class="text-left pb-1">Column</th><th class="text-left pb-1">Type</th></tr></thead>
                    <tbody class="text-gray-700 dark:text-gray-300">

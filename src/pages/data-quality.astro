<style>
  /* Accordion: collapsed by default */
  .check-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
  }
  .check-card.active .check-content {
    max-height: 800px;
  }
  /* Chevron rotation */
  .check-chevron {
    transition: transform 0.3s ease;
  }
  .check-card.active .check-chevron {
    transform: rotate(180deg);
  }
  /* Tab panel fade-in */
  .tabpanel-active {
    animation: tabFadeIn 0.25s ease-out;
  }
  @keyframes tabFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.pillar-tab');
    const panels = document.querySelectorAll<HTMLElement>('.tabpanel');
    const pillarCards = document.querySelectorAll<HTMLButtonElement>('[data-pillar-card]');
    const pillars = ['conformance', 'completeness', 'plausibility'] as const;

    const tabColors: Record<string, { active: string; bg: string; inactive: string }> = {
      conformance: {
        active: 'text-clif-burgundy',
        bg: 'bg-clif-burgundy/10',
        inactive: 'text-gray-500 dark:text-gray-400',
      },
      completeness: {
        active: 'text-clif-burgundy',
        bg: 'bg-clif-burgundy/10',
        inactive: 'text-gray-500 dark:text-gray-400',
      },
      plausibility: {
        active: 'text-clif-burgundy',
        bg: 'bg-clif-burgundy/10',
        inactive: 'text-gray-500 dark:text-gray-400',
      },
    };

    function activatePillar(pillar: string) {
      // Update tabs
      tabs.forEach(tab => {
        const p = tab.dataset.pillar!;
        const colors = tabColors[p];
        const isActive = p === pillar;
        tab.setAttribute('aria-selected', String(isActive));
        // Reset classes
        colors.active.split(' ').forEach(c => tab.classList.toggle(c, isActive));
        colors.bg.split(' ').forEach(c => tab.classList.toggle(c, isActive));
        colors.inactive.split(' ').forEach(c => tab.classList.toggle(c, !isActive));
      });

      // Update panels
      panels.forEach(panel => {
        const isTarget = panel.dataset.pillar === pillar;
        if (isTarget) {
          panel.removeAttribute('hidden');
          panel.classList.add('tabpanel-active');
        } else {
          panel.setAttribute('hidden', '');
          panel.classList.remove('tabpanel-active');
        }
      });

      // Update URL hash without scrolling
      history.replaceState(null, '', `#${pillar}`);
    }

    // Tab clicks
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        activatePillar(tab.dataset.pillar!);
      });
    });

    // Overview card clicks
    pillarCards.forEach(card => {
      card.addEventListener('click', (e) => {
        e.preventDefault();
        const pillar = card.dataset.pillarCard!;
        activatePillar(pillar);
        // Scroll to the nav so the panel is visible
        document.getElementById('pillar-nav')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    // Keyboard navigation between tabs
    const tabList = document.getElementById('pillar-nav');
    tabList?.addEventListener('keydown', (e) => {
      const focused = document.activeElement as HTMLButtonElement;
      if (!focused?.classList.contains('pillar-tab')) return;

      const idx = pillars.indexOf(focused.dataset.pillar as typeof pillars[number]);
      let newIdx = idx;

      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault();
        newIdx = (idx + 1) % pillars.length;
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault();
        newIdx = (idx - 1 + pillars.length) % pillars.length;
      } else if (e.key === 'Home') {
        e.preventDefault();
        newIdx = 0;
      } else if (e.key === 'End') {
        e.preventDefault();
        newIdx = pillars.length - 1;
      } else {
        return;
      }

      const newTab = tabs[newIdx];
      newTab.focus();
      activatePillar(pillars[newIdx]);
    });

    // Accordion toggle
    document.querySelectorAll<HTMLButtonElement>('.check-trigger').forEach(trigger => {
      trigger.addEventListener('click', () => {
        const card = trigger.closest('.check-card')!;
        const isActive = card.classList.toggle('active');
        trigger.setAttribute('aria-expanded', String(isActive));
      });
    });

    // Hash-based deep linking on load and hash change
    function handleHash() {
      const hash = location.hash.replace('#', '');
      // Support both old (#conformance) and new (#panel-conformance) formats
      const pillar = hash.replace('panel-', '');
      if (pillars.includes(pillar as typeof pillars[number])) {
        activatePillar(pillar);
      }
    }
    handleHash();
    window.addEventListener('hashchange', handleHash);

    // Back to top
    const backToTopButton = document.getElementById('back-to-top');
    window.addEventListener('scroll', () => {
      if (window.pageYOffset > 300) {
        backToTopButton?.classList.remove('opacity-0', 'invisible');
        backToTopButton?.classList.add('opacity-100', 'visible');
      } else {
        backToTopButton?.classList.remove('opacity-100', 'visible');
        backToTopButton?.classList.add('opacity-0', 'invisible');
      }
    });
    backToTopButton?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>
